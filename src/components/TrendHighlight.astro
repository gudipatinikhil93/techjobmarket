---
interface Mover {
  name: string;
  change: string;
  isUp: boolean;
  type?: string;
}

interface Props {
  title: string;
  movers: Mover[];
  type?: 'weekly' | 'monthly' | 'breakout';
}

const { title, movers, type = 'weekly' } = Astro.props;

const typeConfig = {
  weekly: { label: 'Weekly Movers', color: 'text-brand-cyan', bg: 'bg-brand-cyan/10' },
  monthly: { label: 'Monthly Momentum', color: 'text-brand-blue', bg: 'bg-brand-blue/10' },
  breakout: { label: 'Breakout Skills', color: 'text-brand-amber', bg: 'bg-brand-amber/10' }
};

const config = typeConfig[type];
---

<div class="glass-panel p-6 rounded-2xl border-white/5 bg-black/40 group hover:border-white/10 transition-all duration-300">
  <div class="flex items-center justify-between mb-8">
    <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-white/50">{title}</h3>
    <span class={`px-2 py-0.5 rounded text-[10px] font-mono font-bold uppercase ${config.color} ${config.bg}`}>
      {config.label}
    </span>
  </div>

  <div class="space-y-6">
    {movers.map(mover => (
      <div class="group/item">
        <div class="flex justify-between items-center mb-2">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-white group-hover/item:text-brand-cyan transition-colors">{mover.name}</span>
            {mover.type && <span class="text-[9px] font-mono text-muted-foreground uppercase tracking-wider">{mover.type}</span>}
          </div>
          <span class={`text-xs font-mono font-bold ${mover.isUp ? 'text-brand-cyan' : 'text-brand-magenta'}`}>
            {mover.isUp ? '+' : ''}{mover.change}
          </span>
        </div>
        <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
          <div 
            class={`h-full transition-all duration-1000 group-hover/item:scale-x-105 origin-left ${mover.isUp ? 'bg-brand-cyan' : 'bg-brand-magenta'}`} 
            style={`width: ${Math.abs(parseFloat(mover.change))}%`}
          ></div>
        </div>
      </div>
    ))}
  </div>
</div>
