---
interface Props {
  title: string;
  value: string;
  subValue?: string;
  trend?: {
    value: string;
    isUp: boolean;
    neutral?: boolean;
  };
  type?: 'default' | 'positive' | 'negative' | 'warning' | 'info';
  countTarget?: number;
  countFormat?: 'number' | 'currency' | 'percent';
}

const { title, value, subValue, trend, type = 'default', countTarget, countFormat } = Astro.props;

const typeColors = {
  default: 'text-white',
  positive: 'text-brand-cyan',
  negative: 'text-brand-magenta',
  warning: 'text-brand-amber',
  info: 'text-brand-blue'
};

const trendColor = trend?.neutral ? 'text-muted-foreground' : (trend?.isUp ? 'text-brand-cyan' : 'text-brand-magenta');
const trendIcon = trend?.neutral ? '→' : (trend?.isUp ? '↑' : '↓');
---

<div class="flex flex-col p-4 rounded-xl bg-white/[0.03] border border-white/10 hover:border-white/25 hover:bg-white/[0.05] hover:-translate-y-1 transition-all duration-300 group shadow-sm hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] relative overflow-hidden cinematic-glow backdrop-blur-sm">
  <!-- Terminal Inner Glow -->
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
  
  <div class="flex justify-between items-start mb-2 relative z-10">
    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground group-hover:text-white/70 transition-colors">{title}</span>
    {trend && (
      <span class={`text-[10px] font-mono font-bold flex items-center gap-1 ${trendColor} drop-shadow-[0_0_8px_rgba(0,0,0,0.5)]`}>
        <span class={!trend.neutral ? "animate-subtle-pulse" : ""}>{trendIcon}</span> {trend.value}
      </span>
    )}
  </div>
  
  <div class="flex items-baseline gap-2 relative z-10">
    <span 
      class={`text-2xl font-bold tracking-tight ${typeColors[type]} drop-shadow-[0_2px_4px_rgba(0,0,0,0.3)]`}
      data-count-target={countTarget}
      data-count-format={countFormat}
    >
      {value}
    </span>
    {subValue && <span class="text-xs text-muted-foreground font-medium group-hover:text-muted-foreground/80 transition-colors">{subValue}</span>}
  </div>
  
  <div class="transition-opacity duration-500 group-hover:opacity-100 opacity-95 relative z-10">
    <slot />
  </div>
</div>
