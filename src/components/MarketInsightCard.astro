---
interface Props {
  title: string;
  value: string;
  subValue?: string;
  trend?: {
    value: string;
    isUp: boolean;
    neutral?: boolean;
  };
  type?: 'default' | 'positive' | 'negative' | 'warning' | 'info';
  countTarget?: number;
  countFormat?: 'number' | 'currency' | 'percent';
}

const { title, value, subValue, trend, type = 'default', countTarget, countFormat } = Astro.props;

const typeColors = {
  default: 'text-white',
  positive: 'text-brand-cyan',
  negative: 'text-brand-magenta',
  warning: 'text-brand-amber',
  info: 'text-brand-blue'
};

const trendColor = trend?.neutral ? 'text-muted-foreground' : (trend?.isUp ? 'text-brand-cyan' : 'text-brand-magenta');
const trendIcon = trend?.neutral ? '→' : (trend?.isUp ? '↑' : '↓');
---

<div class="flex flex-col p-4 rounded-xl glass-panel border-white/5 bg-black/40 hover:border-white/20 hover:bg-white/[0.02] transition-[transform,border-color,background-color] duration-300 ease-out group shadow-lg hover:shadow-brand-blue/5 relative overflow-hidden cinematic-glow will-change-transform">
  <!-- Terminal Inner Glow (Optimized) -->
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none opacity-50 group-hover:opacity-80 transition-opacity duration-500"></div>
  
  <div class="flex justify-between items-start mb-2 relative z-10">
    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground group-hover:text-white/70 transition-colors duration-300">{title}</span>
    {trend && (
      <span class={`text-[10px] font-mono font-bold flex items-center gap-1 ${trendColor}`}>
        <span class={!trend.neutral ? "animate-subtle-pulse" : ""}>{trendIcon}</span> {trend.value}
      </span>
    )}
  </div>
  
  <div class="flex items-baseline gap-2 relative z-10">
    <span 
      class={`text-2xl font-bold tracking-tight ${typeColors[type]}`}
      data-count-target={countTarget}
      data-count-format={countFormat}
    >
      {value}
    </span>
    {subValue && <span class="text-xs text-muted-foreground font-medium group-hover:text-muted-foreground/80 transition-colors duration-300">{subValue}</span>}
  </div>
  
  <div class="transition-opacity duration-500 group-hover:opacity-100 opacity-95 relative z-10">
    <slot />
  </div>
</div>

<style>
  /* Use hardware acceleration for the lift */
  .group:hover {
    transform: translate3d(0, -4px, 0);
  }

  @media (max-width: 768px) {
    .group:hover {
      transform: none;
    }
  }
</style>
