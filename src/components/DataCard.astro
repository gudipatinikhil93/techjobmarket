---
interface Props {
  title: string;
  value: string;
  trend?: {
    value: string;
    isUp: boolean;
  };
  description?: string;
  icon?: string;
}

const { title, value, trend, description } = Astro.props;
---

<div class="group relative overflow-hidden rounded-lg border border-white/10 bg-card p-6 transition-all hover:border-white/20 hover:bg-white/[0.02]">
  <div class="flex flex-col gap-1">
    <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground font-mono">{title}</p>
    <div class="flex items-baseline gap-2">
      <h3 class="text-2xl font-bold tracking-tight text-white">{value}</h3>
      {trend && (
        <span class={`text-xs font-semibold ${trend.isUp ? 'text-brand-cyan' : 'text-brand-magenta'}`}>
          {trend.isUp ? '↑' : '↓'} {trend.value}
        </span>
      )}
    </div>
    {description && <p class="mt-2 text-sm text-muted-foreground">{description}</p>}
  </div>
  
  <!-- Subtle decoration -->
  <div class="absolute -right-4 -top-4 h-16 w-16 rounded-full bg-white/[0.02] blur-2xl group-hover:bg-brand-cyan/5 transition-colors"></div>
</div>
