---
import { getRegionConfig } from '../regions';

interface Props {
  region?: string;
}

const { region = "us" } = Astro.props;
const regionConfig = getRegionConfig(region);

const footerSections = [
  {
    title: "Market",
    links: [
      { href: `/${region}/roles`, label: "Trending Roles" },
      { href: `/${region}/skills`, label: "Skill Demand" },
      { href: `/${region}/salaries`, label: "Salary Benchmarks" },
      { href: `/${region}/cities`, label: "Hiring Hubs" },
    ],
  },
  {
    title: "Insights",
    links: [
      { href: `/${region}/trends`, label: "Market Trends" },
    ],
  },
  {
    title: "Platform",
    links: [
      { href: `/${region}/about`, label: "About Us" },
      { href: `/${region}/privacy-policy`, label: "Privacy Policy" },
      { href: `/${region}/terms-and-conditions`, label: "Terms & Conditions" },
      { href: `/${region}/contact`, label: "Contact" },
    ],
  },
  {
    title: "Popular Roles",
    links: [
      { href: `/${region}/role/Software%20Engineer`, label: "Software Engineer" },
      { href: `/${region}/role/Frontend%20Developer`, label: "Frontend Developer" },
      { href: `/${region}/role/Data%20Analyst`, label: "Data Analyst" },
      { href: `/${region}/role/Product%20Manager`, label: "Product Manager" },
    ],
  },
];
---

<footer class="border-t border-white/10 bg-black py-24 reveal-on-scroll relative overflow-hidden cinematic-glow gpu-accelerated">
  <!-- Atmospheric Footer Layer (Optimized) -->
  <div class="absolute inset-0 -z-10 pointer-events-none overflow-hidden opacity-30 md:opacity-100" aria-hidden="true">
    <div class="absolute bottom-0 right-0 w-full h-full bg-[radial-gradient(circle_at_bottom_right,rgba(0,124,240,0.05)_0%,transparent_60%)]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-2 gap-12 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-2 lg:col-span-1">
        <a href={`/${region}`} class="flex items-center gap-2 mb-8 group translate-3d-lift">
          <img src="/favicon.svg" alt="TechJobMarket Logo" class="h-6 w-6 group-hover:rotate-12 transition-transform" />
          <span class="text-xl font-bold group-hover:text-brand-cyan transition-colors tracking-tight">TechJobMarket</span>
        </a>
        <p class="text-sm text-muted-foreground max-w-xs leading-relaxed italic opacity-80">
          The intelligence platform for the <strong>current {regionConfig.name} tech job market</strong>. Providing real-time insights into hiring trends and salary data.
        </p>
      </div>
      
      {footerSections.map(section => (
        <div class="transition-transform duration-300">
          <h3 class="text-[10px] font-bold text-white mb-8 uppercase tracking-[0.25em] font-mono opacity-40">{section.title}</h3>
          <ul class="space-y-4">
            {section.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground hover:text-brand-cyan transition-all hover:translate-x-1 inline-block hover:translate-3d-right">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="mt-24 border-t border-white/5 pt-10 flex flex-col md:flex-row justify-between gap-6">
      <p class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">
        © 2026 TechJobMarket Intelligence Terminal. Not a job board.
      </p>
      <div class="flex gap-8">
        <a href={`/${region}/privacy-policy`} class="text-[10px] font-mono text-muted-foreground hover:text-white transition-colors uppercase tracking-widest">Privacy</a>
        <a href={`/${region}/terms-and-conditions`} class="text-[10px] font-mono text-muted-foreground hover:text-white transition-colors uppercase tracking-widest">Terms</a>
      </div>
    </div>
  </div>
</footer>

