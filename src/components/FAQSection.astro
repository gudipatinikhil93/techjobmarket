---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<section class="py-20 lg:py-32 border-t border-white/5 bg-black reveal-on-scroll">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-white mb-4">Frequently Asked Questions</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        Deep dive into common queries about the US Tech Job Market with data-driven insights.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      {faqs.map((faq, index) => (
        <div class="border border-white/10 rounded-lg mb-4 bg-white/[0.02] hover:bg-white/[0.04] transition-colors group">
          <button
            class="faq-question flex justify-between items-center w-full p-5 text-left text-lg font-semibold text-white hover:text-brand-cyan transition-colors focus:outline-none"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
          >
            {faq.question}
            <svg class="w-5 h-5 transform transition-transform duration-500 opacity-50 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div 
            id={`faq-answer-${index}`} 
            class="faq-answer grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-out overflow-hidden"
          >
            <div class="min-h-0">
              <div class="p-5 pt-0 text-muted-foreground prose prose-invert max-w-none leading-relaxed">
                <p>{faq.answer}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFAQ() {
    const buttons = document.querySelectorAll('.faq-question');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const answer = button.nextElementSibling as HTMLElement;
        const svg = button.querySelector('svg');
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        // Close all other open answers
        buttons.forEach(otherButton => {
          if (otherButton !== button) {
            otherButton.setAttribute('aria-expanded', 'false');
            const otherAnswer = otherButton.nextElementSibling as HTMLElement;
            if (otherAnswer) otherAnswer.style.gridTemplateRows = '0fr';
            otherButton.querySelector('svg')?.classList.remove('rotate-180');
          }
        });

        // Toggle current answer
        if (isExpanded) {
          button.setAttribute('aria-expanded', 'false');
          answer.style.gridTemplateRows = '0fr';
          svg?.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          answer.style.gridTemplateRows = '1fr';
          svg?.classList.add('rotate-180');
        }
      });
    });
  }

  // Initialize
  initFAQ();
  document.addEventListener('astro:after-swap', initFAQ);
</script>