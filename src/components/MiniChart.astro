---
interface Props {
  data: number[];
  color?: string;
  height?: number;
}

const { data, color = '#50e3c2', height = 40 } = Astro.props;

// Calculate SVG path
const max = Math.max(...data, 1);
const min = Math.min(...data, 0);
const range = max - min || 1;

const points = data.map((val, i) => {
  const x = (i / (data.length - 1)) * 100;
  const y = 100 - ((val - min) / range) * 100;
  return `${x},${y}`;
}).join(' ');
---

<div class="w-full mt-4" style={`height: ${height}px`}>
  <svg viewBox="0 0 100 100" preserveAspectRatio="none" class="w-full h-full overflow-visible">
    <polyline
      fill="none"
      stroke={color}
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
      points={points}
      class="drop-shadow-[0_0_8px_rgba(80,227,194,0.3)]"
    />
  </svg>
</div>
