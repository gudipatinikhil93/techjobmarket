---
interface Entity {
  name: string;
  metrics: {
    label: string;
    value: string;
    score: number; // 0-100
  }[];
}

interface Props {
  title: string;
  entities: Entity[];
  category?: string;
}

const { title, entities, category } = Astro.props;
---

<div class="p-8 rounded-3xl glass-panel relative overflow-hidden bg-black/20 reveal-on-scroll">
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.01] to-transparent pointer-events-none"></div>
  
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12 relative z-10">
    <div>
      {category && <span class="text-[10px] font-mono text-brand-cyan font-bold uppercase tracking-[0.3em] mb-2 block">{category}</span>}
      <h2 class="text-2xl font-bold text-white tracking-tight">{title}</h2>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-12 relative z-10">
    {entities.map(entity => (
      <div class="space-y-8">
        <div class="flex items-center gap-4">
          <div class="h-10 w-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center font-bold text-lg text-white group-hover:text-brand-cyan transition-colors">
            {entity.name[0]}
          </div>
          <h3 class="text-lg font-bold text-white">{entity.name}</h3>
        </div>

        <div class="space-y-6">
          {entity.metrics.map(metric => (
            <div>
              <div class="flex justify-between text-[10px] font-mono text-muted-foreground uppercase tracking-widest mb-2">
                <span>{metric.label}</span>
                <span class="text-white">{metric.value}</span>
              </div>
              <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                <div 
                  class="h-full bg-brand-cyan/60 transition-all duration-1000 group-hover:bg-brand-cyan" 
                  style={`width: ${metric.score}%`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="mt-12 pt-8 border-t border-white/5 flex justify-center relative z-10">
    <div class="flex gap-8 items-center">
      <div class="flex items-center gap-2">
        <div class="h-2 w-2 rounded-full bg-brand-cyan"></div>
        <span class="text-[9px] font-mono text-muted-foreground uppercase tracking-wider">Advantage</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="h-2 w-2 rounded-full bg-white/20"></div>
        <span class="text-[9px] font-mono text-muted-foreground uppercase tracking-wider">Benchmark</span>
      </div>
    </div>
  </div>
</div>
