---
interface Props {
  title: string;
  summary: string;
  metric?: {
    label: string;
    value: string;
    trend?: string;
    isUp?: boolean;
  };
  type?: 'default' | 'positive' | 'negative' | 'warning' | 'info';
  footer?: string;
}

const { title, summary, metric, type = 'default', footer } = Astro.props;

const typeColors = {
  default: 'border-white/10 text-white',
  positive: 'border-brand-cyan/20 text-brand-cyan',
  negative: 'border-brand-magenta/20 text-brand-magenta',
  warning: 'border-brand-amber/20 text-brand-amber',
  info: 'border-brand-blue/20 text-brand-blue'
};

const bgColors = {
  default: 'bg-white/[0.02]',
  positive: 'bg-brand-cyan/5',
  negative: 'bg-brand-magenta/5',
  warning: 'bg-brand-amber/5',
  info: 'bg-brand-blue/5'
};

const accentColors = {
  default: 'bg-white/10',
  positive: 'bg-brand-cyan/20',
  negative: 'bg-brand-magenta/20',
  warning: 'bg-brand-amber/20',
  info: 'bg-brand-blue/20'
};
---

<div class={`relative group overflow-hidden rounded-2xl border ${typeColors[type]} ${bgColors[type]} p-6 transition-all duration-500 hover:scale-[1.01] hover:bg-black/40 reveal-on-scroll`}>
  <!-- Background Glow -->
  <div class={`absolute -right-8 -top-8 h-32 w-32 rounded-full blur-[60px] opacity-10 group-hover:opacity-20 transition-opacity ${accentColors[type]}`}></div>
  
  <div class="relative z-10">
    <div class="flex items-center gap-2 mb-4">
      <div class={`h-1.5 w-1.5 rounded-full ${accentColors[type]} ${type === 'positive' || type === 'negative' ? 'animate-pulse' : ''}`}></div>
      <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] opacity-60 group-hover:opacity-100 transition-opacity">{title}</span>
    </div>

    <h3 class="text-xl font-bold mb-3 tracking-tight group-hover:text-white transition-colors">{summary}</h3>

    {metric && (
      <div class="mt-6 flex items-end gap-4 border-t border-white/5 pt-6">
        <div>
          <p class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-1">{metric.label}</p>
          <p class={`text-3xl font-bold tracking-tighter ${typeColors[type]}`}>{metric.value}</p>
        </div>
        {metric.trend && (
          <div class={`mb-1 px-2 py-0.5 rounded text-[10px] font-mono font-bold ${metric.isUp ? 'text-brand-cyan bg-brand-cyan/10' : 'text-brand-magenta bg-brand-magenta/10'}`}>
            {metric.isUp ? '↑' : '↓'} {metric.trend}
          </div>
        )}
      </div>
    )}

    {footer && (
      <div class="mt-6 text-[10px] font-mono text-muted-foreground/60 italic group-hover:text-muted-foreground/80 transition-colors">
        {footer}
      </div>
    )}
  </div>
</div>
