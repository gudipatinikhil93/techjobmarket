---
import "../styles/global.css";

import AtmosphereLayer from "../components/AtmosphereLayer.astro";
import { getRegionConfig } from "../regions";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: string;
	noindex?: boolean;
	heroActive?: boolean;
	region?: string;
}

const { 
	region = "us",
	heroActive = false,
	type = "website",
	image = "/og-image.png",
	canonicalURL = Astro.url.href,
} = Astro.props;

const regionConfig = getRegionConfig(region);

// Automatically noindex beta/private regions
const noindex = Astro.props.noindex || !regionConfig.public;

const { 
	title = regionConfig.seo.defaultTitle, 
	description = regionConfig.seo.defaultDescription,
} = Astro.props;

const siteName = "TechJobMarket";
const twitterHandle = "@TechJobMarket"; // Placeholder
const currentOrigin = Astro.url.origin;
---

<!doctype html>
<html lang={regionConfig.locale} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Jobmarket" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, currentOrigin)} />
		<meta property="og:site_name" content={siteName} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, currentOrigin)} />
		<meta property="twitter:site" content={twitterHandle} />

		<link rel="canonical" href={canonicalURL} />
		
		<!-- Preload Critical Fonts -->
		<link rel="preload" href="/fonts/geist-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/geist-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin />

		<!-- Critical CSS -->
		<style is:inline>
			:root {
				--color-background: #000000;
				--color-foreground: #ffffff;
				--color-brand-cyan: #50e3c2;
			}
			html {
				background-color: #000;
			}
			body {
				background-color: var(--color-background);
				color: var(--color-foreground);
				margin: 0;
				min-height: 100vh;
				font-family: system-ui, -apple-system, sans-serif;
			}
			.atmosphere-system {
				position: fixed;
				inset: 0;
				z-index: -10;
				background-color: #000;
				transform: translate3d(0,0,0);
			}
			nav {
				height: 64px;
				background-color: rgba(0,0,0,0.4);
			}
		</style>

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline define:vars={{ currentOrigin, region }}>
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "TechJobMarket",
				"alternateName": "TJM",
				"url": `${currentOrigin}/${region}`,
				"potentialAction": {
					"@type": "SearchAction",
					"target": `${currentOrigin}/${region}/search?q={search_term_string}`,
					"query-input": "required name=search_term_string"
				}
			}
		</script>
		<script type="application/ld+json" is:inline define:vars={{ currentOrigin, region, regionConfig }}>
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "TechJobMarket",
				"url": `${currentOrigin}/${region}`,
				"logo": `${currentOrigin}/favicon.svg`,
				"image": `${currentOrigin}/og-image.png`,
				"description": `TechJobMarket is a real-time ${regionConfig.name} tech job market intelligence platform providing insights on hiring trends, salaries, and layoffs.`,
				"sameAs": [
					"https://twitter.com/techjobmarket",
					"https://linkedin.com/company/techjobmarket",
					"https://github.com/techjobmarket"
				]
			}
		</script>
		<!-- Google tag (gtag.js) - Aggressively Deferred for Performance -->
		<script is:inline define:vars={{ region }}>
			(function() {
				const GA_ID = 'G-2V7Y2B2ZGX';
				let loaded = false;

				function loadAnalytics() {
					if (loaded) return;
					loaded = true;

					const script = document.createElement('script');
					script.async = true;
					script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
					document.head.appendChild(script);

					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', GA_ID, { 
						'anonymize_ip': true,
						'page_path': window.location.pathname,
						'send_page_view': true,
						'region_context': region
					});
				}

				// Strategy: Load on interaction OR after long idle (5s)
				const triggerEvents = ['mousedown', 'mousemove', 'touchstart', 'scroll', 'keydown'];
				
				function triggerLoad() {
					loadAnalytics();
					triggerEvents.forEach(e => window.removeEventListener(e, triggerLoad));
				}

				// Add listeners for interaction
				triggerEvents.forEach(e => window.addEventListener(e, triggerLoad, { passive: true }));

				// Fallback to idle callback if no interaction
				if ('requestIdleCallback' in window) {
					requestIdleCallback(() => {
						setTimeout(loadAnalytics, 5000);
					});
				} else {
					window.addEventListener('load', () => {
						setTimeout(loadAnalytics, 5000);
					});
				}
			})();
		</script>
	</head>
	<body class={`min-h-screen selection:bg-brand-cyan selection:text-black relative ${heroActive ? 'hero-active' : ''}`}>
		<AtmosphereLayer />

		<slot />

		<script is:inline define:vars={{ regionConfig }}>
			// Optimized Shared Observer for Scroll Reveal and Count-up
			const sharedObserverOptions = {
				threshold: 0.1,
				rootMargin: "0px 0px -50px 0px"
			};

			const currencyFormatter = new Intl.NumberFormat(regionConfig.locale, {
				style: 'currency',
				currency: regionConfig.currency.code,
				maximumFractionDigits: 0
			});

			const numberFormatter = new Intl.NumberFormat(regionConfig.locale);

			function animateCountUp(el) {
				const target = parseFloat(el.dataset.countTarget || "0");
				const format = el.dataset.countFormat;
				const duration = 1500;
				const startTime = performance.now();

				function update(currentTime) {
					const elapsed = currentTime - startTime;
					const progress = Math.min(elapsed / duration, 1);
					
					// Ease out expo
					const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
					const currentCount = easeProgress * target;
					
					let text = "";
					if (format === 'currency') {
						if (regionConfig.currency.format === 'INR') {
							// For INR, often show in LPA
							const lpa = currentCount / 100000;
							text = `₹${lpa.toFixed(1)}L`;
						} else {
							text = currencyFormatter.format(Math.floor(currentCount));
						}
					} else if (format === 'percent') {
						text = `${Math.floor(currentCount)}%`;
					} else {
						text = numberFormatter.format(Math.floor(currentCount));
					}

					if (el.textContent !== text) {
						el.textContent = text;
					}

					if (progress < 1) {
						requestAnimationFrame(update);
					}
				}

				requestAnimationFrame(update);
			}

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const target = entry.target;
						
						// Handle Scroll Reveal
						if (target.classList.contains('reveal-on-scroll')) {
							target.classList.add('is-visible');
						}
						
						// Handle Count-up
						if (target.hasAttribute('data-count-target')) {
							requestAnimationFrame(() => animateCountUp(target));
						}

						observer.unobserve(target);
					}
				});
			}, sharedObserverOptions);

			function init() {
				// Observe both reveal and count elements with a single observer
				document.querySelectorAll('.reveal-on-scroll, [data-count-target]').forEach(el => {
					observer.observe(el);
				});
			}

			// Run on load and after swaps
			init();
			document.addEventListener('astro:after-swap', init);
		</script>
	</body>
</html>


<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>