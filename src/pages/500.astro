---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	error: unknown;
}

const { error } = Astro.props;

// Determine if we should show error details (only in dev ideally, but we'll show a safe version)
const errorMessage = error instanceof Error ? error.message : "An unexpected server error occurred.";
---

<Layout 
	title="500: Internal Server Error | TechJobMarket"
	description="Something went wrong on our end. We're working on fixing the data pipeline."
	noindex={true}
>
	<Navbar />
	
	<main class="relative bg-black min-h-screen selection:bg-brand-cyan/30 flex flex-col justify-center items-center py-20">
		<!-- Mesh Gradient Background (consistent with Home) -->
		<div class="absolute inset-0 mesh-gradient opacity-30 -z-10"></div>
		<div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-magenta/10 rounded-full blur-[120px] -z-10 pointer-events-none translate-x-1/3 -translate-y-1/3"></div>

		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
			<div class="flex flex-col items-center gap-6">
				<!-- Animated Pulse Indicator -->
				<div class="flex items-center gap-3 mb-2">
					<div class="relative flex h-3 w-3">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
						<span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
					</div>
					<span class="text-sm font-mono text-red-500 tracking-wider uppercase">Error 500</span>
				</div>

				<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-tight">
					Pipeline <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white/80 to-white/40">Interruption</span>
				</h1>
				
				<p class="max-w-xl text-lg md:text-xl text-muted-foreground mb-8 leading-relaxed">
					Our intelligence engines encountered an unexpected issue while processing your request. Our engineers have been notified.
				</p>

				<div class="flex flex-col sm:flex-row gap-4 mb-12">
					<button 
						onclick="window.location.reload()"
						class="px-8 py-4 rounded-full bg-white text-black font-bold hover:bg-brand-cyan transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(255,255,255,0.1)]"
					>
						Retry Request
					</button>
					<a 
						href="/" 
						class="px-8 py-4 rounded-full bg-white/5 text-white border border-white/10 font-bold hover:bg-white/10 transition-all"
					>
						Back to Dashboard
					</a>
				</div>

				<!-- Error Details (Safe) -->
				<div class="w-full max-w-2xl text-left">
					<div class="p-6 rounded-2xl bg-red-500/5 border border-red-500/10">
						<h3 class="text-xs font-mono text-red-500 uppercase tracking-widest mb-4">Diagnostics</h3>
						<code class="text-sm text-muted-foreground break-words block">
							{errorMessage}
						</code>
						<p class="mt-4 text-[10px] text-muted-foreground/50 font-mono">
							Trace ID: {Math.random().toString(36).substring(2, 15).toUpperCase()}
						</p>
					</div>
				</div>

				<!-- Stats-like 500 Detail -->
				<div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-4 w-full max-w-2xl">
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Engine Status</span>
						<span class="text-xl font-bold text-white">Critical</span>
					</div>
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Recovery</span>
						<span class="text-xl font-bold text-white">Automatic</span>
					</div>
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Data Integrity</span>
						<span class="text-xl font-bold text-white">Safe</span>
					</div>
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.mesh-gradient {
		background-image: 
			radial-gradient(at 0% 0%, rgba(255, 0, 128, 0.05) 0px, transparent 50%),
			radial-gradient(at 100% 0%, rgba(121, 40, 202, 0.05) 0px, transparent 50%),
			radial-gradient(at 100% 100%, rgba(255, 0, 128, 0.05) 0px, transparent 50%),
			radial-gradient(at 0% 100%, rgba(121, 40, 202, 0.05) 0px, transparent 50%);
	}
</style>
