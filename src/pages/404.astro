---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;
---

<Layout 
	title="404: Page Not Found | TechJobMarket"
	description="The page you are looking for does not exist. Return to TechJobMarket for US tech job market intelligence."
	noindex={true}
>
	<Navbar />
	
	<main class="relative bg-black min-h-screen selection:bg-brand-cyan/30 flex flex-col justify-center items-center">
		<!-- Mesh Gradient Background (consistent with Home) -->
		<div class="absolute inset-0 mesh-gradient opacity-30 -z-10"></div>
		<div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-blue/10 rounded-full blur-[120px] -z-10 pointer-events-none translate-x-1/3 -translate-y-1/3"></div>

		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
			<div class="flex flex-col items-center gap-6">
				<!-- Animated Pulse Indicator -->
				<div class="flex items-center gap-3 mb-2">
					<div class="relative flex h-3 w-3">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-magenta opacity-75"></span>
						<span class="relative inline-flex rounded-full h-3 w-3 bg-brand-magenta"></span>
					</div>
					<span class="text-sm font-mono text-brand-magenta tracking-wider uppercase">Error 404</span>
				</div>

				<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-tight">
					Lost in the <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white/80 to-white/40">Market Data</span>
				</h1>
				
				<p class="max-w-xl text-lg md:text-xl text-muted-foreground mb-8 leading-relaxed">
					The page you're looking for has moved, been renamed, or never existed. Let's get you back to the intelligence that matters.
				</p>

				<div class="flex flex-col sm:flex-row gap-4">
					<a 
						href="/" 
						class="px-8 py-4 rounded-full bg-white text-black font-bold hover:bg-brand-cyan transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(255,255,255,0.1)]"
					>
						Return Home
					</a>
					<a 
						href="/search" 
						class="px-8 py-4 rounded-full bg-white/5 text-white border border-white/10 font-bold hover:bg-white/10 transition-all"
					>
						Search Market
					</a>
				</div>

				<!-- Stats-like 404 Detail -->
				<div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-4 w-full max-w-2xl">
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Error Type</span>
						<span class="text-xl font-bold text-white">Not Found</span>
					</div>
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Status Code</span>
						<span class="text-xl font-bold text-white">404</span>
					</div>
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Intelligence</span>
						<span class="text-xl font-bold text-white">Offline</span>
					</div>
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.mesh-gradient {
		background-image: 
			radial-gradient(at 0% 0%, rgba(0, 242, 254, 0.05) 0px, transparent 50%),
			radial-gradient(at 100% 0%, rgba(121, 40, 202, 0.05) 0px, transparent 50%),
			radial-gradient(at 100% 100%, rgba(0, 242, 254, 0.05) 0px, transparent 50%),
			radial-gradient(at 0% 100%, rgba(121, 40, 202, 0.05) 0px, transparent 50%);
	}
</style>
