---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const salaryData = [
  { 
    track: "AI & Machine Learning", 
    levels: [
      { exp: "0-2y", range: "₹12L - ₹25L" },
      { exp: "2-5y", range: "₹25L - ₹55L" },
      { exp: "5-10y", range: "₹55L - ₹1.2Cr" },
      { exp: "10y+", range: "₹1.2Cr+" }
    ]
  },
  { 
    track: "Backend Engineering", 
    levels: [
      { exp: "0-2y", range: "₹8L - ₹18L" },
      { exp: "2-5y", range: "₹18L - ₹40L" },
      { exp: "5-10y", range: "₹40L - ₹85L" },
      { exp: "10y+", range: "₹85L+" }
    ]
  },
  { 
    track: "Frontend & Fullstack", 
    levels: [
      { exp: "0-2y", range: "₹7L - ₹16L" },
      { exp: "2-5y", range: "₹16L - ₹35L" },
      { exp: "5-10y", range: "₹35L - ₹75L" },
      { exp: "10y+", range: "₹75L+" }
    ]
  },
  { 
    track: "Cloud & DevOps", 
    levels: [
      { exp: "0-2y", range: "₹9L - ₹20L" },
      { exp: "2-5y", range: "₹20L - ₹45L" },
      { exp: "5-10y", range: "₹45L - ₹95L" },
      { exp: "10y+", range: "₹95L+" }
    ]
  },
  { 
    track: "Product Management", 
    levels: [
      { exp: "0-2y", range: "₹10L - ₹22L" },
      { exp: "2-5y", range: "₹22L - ₹50L" },
      { exp: "5-10y", range: "₹50L - ₹90L" },
      { exp: "10y+", range: "₹90L+" }
    ]
  },
  { 
    track: "Data Engineering", 
    levels: [
      { exp: "0-2y", range: "₹8L - ₹20L" },
      { exp: "2-5y", range: "₹20L - ₹48L" },
      { exp: "5-10y", range: "₹48L - ₹90L" },
      { exp: "10y+", range: "₹90L+" }
    ]
  }
];
---

<Layout title="Salary Benchmarks 2026 | JobMarketIndia">
  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Salary Benchmarks</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Market-clearing compensation ranges for Tier-1 Indian tech companies in 2026. Figures are inclusive of base and performance bonuses.</p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-white/10 text-left">
              <th class="py-6 px-4 text-sm font-mono text-muted-foreground uppercase tracking-widest">Tech Track</th>
              <th class="py-6 px-4 text-sm font-mono text-muted-foreground uppercase tracking-widest">0-2 Years</th>
              <th class="py-6 px-4 text-sm font-mono text-muted-foreground uppercase tracking-widest">2-5 Years</th>
              <th class="py-6 px-4 text-sm font-mono text-muted-foreground uppercase tracking-widest">5-10 Years</th>
              <th class="py-6 px-4 text-sm font-mono text-muted-foreground uppercase tracking-widest">10+ Years</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {salaryData.map(track => (
              <tr class="group hover:bg-white/[0.02] transition-colors">
                <td class="py-8 px-4">
                  <span class="text-lg font-bold text-white group-hover:text-brand-cyan transition-colors">{track.track}</span>
                </td>
                {track.levels.map(level => (
                  <td class="py-8 px-4">
                    <span class="text-sm font-medium text-white/80">{level.range}</span>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 rounded-2xl border border-white/10 bg-card">
          <h3 class="text-xl font-bold text-white mb-4">Stock Options & RSUs</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            In 2026, many Indian startups have pivoted to "Cash-First" models. Early-stage equity is being replaced by quarterly performance-linked liquidity events. Public companies continue to offer RSUs with 4-year vesting, but with shorter cliffs (6 months).
          </p>
        </div>
        <div class="p-8 rounded-2xl border border-white/10 bg-card">
          <h3 class="text-xl font-bold text-white mb-4">The "GenAI Premium"</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Engineers with proven experience in custom model training or RAG-at-scale are commanding a 40-60% premium over traditional full-stack roles. We've seen "Talent Wars" in Bengaluru resulting in signing bonuses exceeding ₹15L for senior AI architects.
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
