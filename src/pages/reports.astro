---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const reports = [
  { id: 1, title: "State of GenAI Hiring: Q1 2026", type: "Quarterly Report", date: "April 2026", size: "4.2 MB", color: "border-brand-cyan" },
  { id: 2, title: "India Tech Salary Guide 2026", type: "Annual Benchmark", date: "Jan 2026", size: "8.5 MB", color: "border-brand-blue" },
  { id: 3, title: "GCC Expansion in Tier-2 Cities", type: "Special Report", date: "March 2026", size: "2.1 MB", color: "border-brand-amber" },
  { id: 4, title: "Weekly Pulse: March Week 4", type: "Weekly Insight", date: "March 28, 2026", size: "1.2 MB", color: "border-white/20" },
  { id: 5, title: "The Rise of Agentic Workflows", type: "Tech Deep-dive", date: "Feb 2026", size: "5.4 MB", color: "border-brand-magenta" },
  { id: 6, title: "Weekly Pulse: March Week 3", type: "Weekly Insight", date: "March 21, 2026", size: "1.1 MB", color: "border-white/20" },
];
---

<Layout title="Market Reports | JobMarketIndia">
  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Intelligence Reports</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Download our data-backed insights on the evolving landscape of tech employment in India.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {reports.map(report => (
          <div class={`group relative p-8 rounded-2xl border ${report.color} bg-card hover:bg-white/[0.02] transition-all cursor-pointer overflow-hidden`}>
            <!-- Decorative background element -->
            <div class="absolute -right-4 -top-4 h-24 w-24 bg-white/[0.03] rotate-12 group-hover:rotate-45 transition-transform"></div>
            
            <div class="flex justify-between items-start mb-12">
              <div class="h-12 w-10 bg-white/10 rounded flex items-center justify-center border border-white/10">
                <div class="w-6 h-0.5 bg-white/40 mb-1"></div>
                <div class="w-4 h-0.5 bg-white/40 mb-1"></div>
                <div class="w-6 h-0.5 bg-white/40"></div>
              </div>
              <span class="text-[10px] font-mono text-muted-foreground uppercase">{report.size}</span>
            </div>
            
            <div>
              <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">{report.type}</p>
              <h3 class="text-xl font-bold text-white mb-6 group-hover:text-white transition-colors leading-tight">{report.title}</h3>
              
              <div class="flex items-center justify-between">
                <span class="text-xs text-muted-foreground">{report.date}</span>
                <button class="text-sm font-bold text-brand-cyan group-hover:underline">Download PDF ↓</button>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-20 p-12 rounded-3xl border border-white/10 bg-gradient-to-r from-card to-black flex flex-col items-center text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Enterprise Data Access</h2>
        <p class="text-muted-foreground max-w-2xl mb-8">Need real-time API access to our hiring indices and salary benchmarks for your HR planning? Our enterprise tier provides direct access to the raw intelligence feed.</p>
        <button class="px-8 py-4 bg-white text-black rounded-pill font-bold hover:bg-brand-cyan transition-colors">
          Contact Enterprise Sales
        </button>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
