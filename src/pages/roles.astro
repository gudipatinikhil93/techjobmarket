---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getAllRoles } from '../services/jobService';

const fallbackRoles = [
  { name: "AI Engineer", category: "Engineering", salary: "₹15L - ₹45L", demand: "Critical" },
  { name: "Full Stack Developer", category: "Engineering", salary: "₹8L - ₹30L", demand: "High" },
  { name: "Product Manager", category: "Product", salary: "₹12L - ₹40L", demand: "High" },
  { name: "Data Scientist", category: "Data", salary: "₹10L - ₹35L", demand: "Very High" },
  { name: "Cloud Architect", category: "Infrastructure", salary: "₹20L - ₹55L", demand: "Critical" },
  { name: "UI/UX Designer", category: "Design", salary: "₹6L - ₹25L", demand: "Medium" },
  { name: "DevOps Engineer", category: "Infrastructure", salary: "₹10L - ₹32L", demand: "High" },
  { name: "Cybersecurity Analyst", category: "Security", salary: "₹12L - ₹38L", demand: "Very High" },
];

const dbRoles = await getAllRoles();

const roles = dbRoles.length > 0
  ? dbRoles.map(r => ({
      name: r.role,
      category: "Tech",
      salary: "Market Rate",
      demand: r.job_count > 50 ? "Critical" : "High"
    }))
  : fallbackRoles;
---

<Layout title="Trending Job Roles in India | JobMarketIndia">
  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Trending Job Roles</h1>
        <p class="text-muted-foreground text-lg">In-depth analysis of the most in-demand roles in India's tech ecosystem.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {roles.map(role => (
          <div class="rounded-xl border border-white/10 bg-card p-6 hover:border-brand-cyan/30 transition-all group">
            <div class="flex justify-between items-start mb-4">
              <span class="text-xs font-mono text-brand-cyan uppercase tracking-widest">{role.category}</span>
              <span class={`px-2 py-0.5 rounded text-[10px] font-bold uppercase ${role.demand === 'Critical' ? 'bg-brand-magenta/20 text-brand-magenta' : 'bg-brand-cyan/20 text-brand-cyan'}`}>
                {role.demand}
              </span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-cyan transition-colors">{role.name}</h3>
            <p class="text-sm text-muted-foreground mb-6">Average Package: <span class="text-white font-medium">{role.salary}</span></p>
            <button class="text-sm font-bold text-white/50 hover:text-white transition-colors">View detailed breakdown →</button>
          </div>
        ))}
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
