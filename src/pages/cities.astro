---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getAllCities } from '../services/jobService';

const fallbackCities = [
  { name: "Bengaluru", index: 9.8, industries: ["Generative AI", "SaaS", "Fintech"], status: "Peak", description: "The Silicon Valley of India continues to lead in GenAI and DeepTech investments." },
  { name: "Hyderabad", index: 9.4, industries: ["Cloud Computing", "Semiconductors", "Global Capability Centers"], status: "High Growth", description: "Massive expansion of GCCs and high-end cloud infrastructure projects." },
  { name: "Pune", index: 8.7, industries: ["Automotive Tech", "Product Engineering", "Cybersecurity"], status: "Stable", description: "Solid demand in specialized engineering and the growing EV tech sector." },
  { name: "Gurugram", index: 8.9, industries: ["Quick Commerce", "Fintech", "B2B Marketplaces"], status: "High", description: "Dominance in consumer tech and high-frequency trading platforms." },
  { name: "Chennai", index: 8.3, industries: ["SaaS", "DeepTech", "Industrial IoT"], status: "Steady", description: "Consistent growth in SaaS and high-end industrial automation." },
  { name: "Mumbai", index: 8.5, industries: ["Fintech", "Media Tech", "Enterprise Software"], status: "Stable", description: "Fintech innovation remains the core driver for the financial capital." },
  { name: "Noida", index: 8.1, industries: ["IT Services", "Data Centers", "Mobile Tech"], status: "Growing", description: "Emerging as a major hub for data centers and large-scale IT operations." },
  { name: "Ahmedabad", index: 7.8, industries: ["Manufacturing Tech", "Fintech", "Renewable Energy"], status: "Emerging", description: "Rapid growth in tech-enabled manufacturing and renewable energy systems." },
];

const dbCities = await getAllCities();

const cities = dbCities.length > 0 
  ? dbCities.map(c => ({
      name: c.city,
      index: Math.min(10, (c.job_count / 100) + 5).toFixed(1),
      industries: ["Tech", "IT Services", "Engineering"],
      status: c.job_count > 50 ? "Peak" : "High Growth",
      description: `Major hub with ${c.job_count} active job listings.`
    }))
  : fallbackCities;
---

<Layout title="Top Hiring Cities in India 2026 | JobMarketIndia">
  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Hiring Hubs</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Geographic distribution of tech demand across India. Data reflects 2026 Q1-Q2 hiring indices.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {cities.map(city => (
          <div class="rounded-xl border border-white/10 bg-card p-6 hover:border-brand-cyan/30 transition-all group flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
              <span class="text-[10px] font-mono text-brand-cyan uppercase tracking-widest font-bold px-2 py-0.5 bg-brand-cyan/10 rounded">{city.status}</span>
              <div class="flex flex-col items-end">
                <span class="text-2xl font-bold text-white">{city.index}</span>
                <span class="text-[10px] text-muted-foreground uppercase font-mono">Hiring Index</span>
              </div>
            </div>
            
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-cyan transition-colors">{city.name}</h3>
            <p class="text-sm text-muted-foreground mb-4 flex-grow">{city.description}</p>
            
            <div class="space-y-3 pt-4 border-t border-white/5">
              <p class="text-[10px] uppercase tracking-wider text-muted-foreground font-bold">Key Industries</p>
              <div class="flex flex-wrap gap-2">
                {city.industries.map(industry => (
                  <span class="text-[10px] bg-white/5 text-white/70 px-2 py-1 rounded-pill border border-white/5">
                    {industry}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="mt-20 p-8 rounded-2xl border border-white/10 bg-gradient-to-br from-card to-black relative overflow-hidden">
        <div class="relative z-10 md:flex items-center justify-between gap-12">
          <div class="mb-8 md:mb-0">
            <h2 class="text-2xl font-bold text-white mb-4">Regional Shift Analysis</h2>
            <p class="text-muted-foreground max-w-xl">In 2026, we've observed a 14% migration of GenAI talent from Tier-1 hubs to emerging clusters in Ahmedabad and Kochi, driven by infrastructure maturity and remote-first policies for senior architects.</p>
          </div>
          <button class="bg-white text-black px-6 py-3 rounded-pill font-bold hover:bg-brand-cyan transition-colors whitespace-nowrap">
            Download Regional Report
          </button>
        </div>
        <div class="absolute -right-24 -bottom-24 h-64 w-64 bg-brand-cyan/10 blur-[100px] rounded-full"></div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
