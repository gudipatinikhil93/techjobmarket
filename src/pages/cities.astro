---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getAllCities } from '../services/jobService';

const dbCities = await getAllCities();

const cities = dbCities.length > 0 
  ? dbCities.map(c => {
      const isPeak = c.job_count > 10; // adjusted threshold for actual data volume
      return {
        name: c.city,
        index: Math.min(10, (c.job_count / 10) + 5).toFixed(1), // scaled for data volume
        industries: ["Tech", "IT Services", "Engineering"], // we'd ideally pull from jobs.skills
        status: isPeak ? "Peak" : "Growing",
        description: `Active US Tech Hub with ${c.job_count} current open listings.`,
        salary: c.avg_salary
      };
    })
  : [];
---

<Layout 
  title="Best Cities for Tech Jobs in US | Top Hiring Hubs"
  description="Discover the top hiring cities in the US current tech job market. Compare tech hubs based on live hiring demand."
>
  <Navbar />
  
  <main class="py-24 bg-black min-h-screen">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Hiring Hubs</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Geographic distribution of tech demand across the United States based on active, live job listings.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {cities.length > 0 ? cities.map(city => (
          <div class="rounded-xl border border-white/10 bg-white/[0.02] p-6 hover:border-brand-cyan/30 transition-all group flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
              <span class={`text-[10px] font-mono uppercase tracking-widest font-bold px-2 py-0.5 rounded ${city.status === 'Peak' ? 'bg-brand-cyan/10 text-brand-cyan' : 'bg-brand-blue/10 text-brand-blue'}`}>
                {city.status}
              </span>
              <div class="flex flex-col items-end">
                <span class="text-2xl font-bold text-white">{city.index}</span>
                <span class="text-[10px] text-muted-foreground uppercase font-mono">Hiring Index</span>
              </div>
            </div>
            
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-cyan transition-colors">{city.name}</h3>
            <p class="text-sm text-muted-foreground mb-4 flex-grow">{city.description}</p>
            
            <div class="space-y-3 pt-4 border-t border-white/5">
              {city.salary > 0 && (
                <div class="mb-2">
                  <span class="text-[10px] uppercase tracking-wider text-muted-foreground font-bold">Avg. Comp: </span>
                  <span class="text-sm font-mono text-white">${(city.salary / 1000).toFixed(0)}k</span>
                </div>
              )}
              <p class="text-[10px] uppercase tracking-wider text-muted-foreground font-bold">Key Industries</p>
              <div class="flex flex-wrap gap-2">
                {city.industries.map(industry => (
                  <span class="text-[10px] bg-white/5 text-white/70 px-2 py-1 rounded-full border border-white/5">
                    {industry}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )) : (
          <div class="col-span-full p-12 text-center text-muted-foreground italic border border-white/10 rounded-xl bg-white/[0.02]">
            Aggregating city-level job data... Please check back later.
          </div>
        )}
      </div>
      
      <div class="mt-20 p-8 rounded-2xl border border-white/10 bg-white/[0.02] relative overflow-hidden">
        <div class="relative z-10 md:flex items-center justify-between gap-12">
          <div class="mb-8 md:mb-0">
            <h2 class="text-2xl font-bold text-white mb-4">Remote vs On-Site Dynamics</h2>
            <p class="text-muted-foreground max-w-xl">While major hubs like San Francisco and New York still command the highest raw volume, the "Remote" designation remains the largest single category for senior technical roles across the US.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
