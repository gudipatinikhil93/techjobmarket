---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { 
  getTopCities, 
  getMarketPulse, 
  getHiringTrends, 
  getSalaryBenchmarks,
  getRemoteTrend,
  getAIHiringMomentum,
  getJuniorHiringDifficulty,
  getTopSkills
} from '../services/jobService';
import { getMarketOutlook } from '../services/outlookService';
import { getLatestInsights } from '../services/aiService';
import { getRecentLayoffs } from '../services/layoffService';
import FAQSection from '../components/FAQSection.astro';
import MarketInsightCard from '../components/MarketInsightCard.astro';
import MiniChart from '../components/MiniChart.astro';

// Fetch real data from services
const marketPulse = await getMarketPulse();
const aiIntelligence = await getLatestInsights();
const topCities = await getTopCities();
const salaryBenchmarks = await getSalaryBenchmarks();
const hiringTrends = await getHiringTrends();
const marketOutlook = await getMarketOutlook();
const remoteTrend = await getRemoteTrend();
const aiMomentum = await getAIHiringMomentum();
const juniorDifficulty = await getJuniorHiringDifficulty();
const recentLayoffs = await getRecentLayoffs(50); // Fetch more to calculate pressure
const topSkills = await getTopSkills();

// Calculate Layoff Pressure (Simple count in last 30 days)
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const recentLayoffsCount = recentLayoffs.filter(l => new Date(l.date) >= thirtyDaysAgo).reduce((acc, l) => acc + (l.layoffs_count || 0), 0);
const previousLayoffsCount = recentLayoffs.filter(l => new Date(l.date) < thirtyDaysAgo).reduce((acc, l) => acc + (l.layoffs_count || 0), 0);
const layoffTrend = previousLayoffsCount > 0 ? ((recentLayoffsCount - previousLayoffsCount) / previousLayoffsCount * 100).toFixed(0) : "0";

// Market Status Logic
const hiringVelocity = marketPulse.hiringIndex;
let marketStatus = "Stable";
let statusColor = "text-white";
let statusBg = "bg-white/10";

if (hiringVelocity > 7.5) {
  marketStatus = "Accelerating";
  statusColor = "text-brand-cyan";
  statusBg = "bg-brand-cyan/10";
} else if (hiringVelocity < 5.0) {
  marketStatus = "Cooling";
  statusColor = "text-brand-magenta";
  statusBg = "bg-brand-magenta/10";
}

// Format numbers
const formatSalary = (num: number) => `$${(num / 1000).toFixed(0)}k`;

const FAQ_CONTENT = [
  {
    question: "How is the current job market?",
    answer: `The current US tech job market in 2026 is dynamic, characterized by significant shifts. While there's a hiring slowdown in some areas, particularly after recent layoffs, demand for specialized skills in AI, cloud computing, and advanced software engineering remains robust. Our data indicates a cautious but active market, with companies prioritizing efficiency and high-impact roles. For software engineers, adapting to AI hiring trends and focusing on in-demand cloud skills is crucial.`
  },
  {
    question: "What is the current job market like?",
    answer: `The 2026 job market is competitive, especially in tech, due to factors like oversaturation in generalist roles and a focus on AI-driven efficiency. We're observing a dual market: high demand for niche, AI-fluent professionals and increased competition for entry-level or less specialized positions. Remote work opportunities continue to be prevalent, but companies are becoming more selective. Understanding current job market trends 2026 is vital for effective job searching.`
  },
  {
    question: "How to keep skills current in changing job market?",
    answer: `To keep skills current in today's rapidly changing job market, continuous learning is paramount. Focus on emerging software engineering trends, particularly in AI, machine learning, and cloud native technologies. Our analytics show a rising demand for skills in areas like generative AI, MLOps, and secure cloud infrastructure. Regularly upskilling through certifications, open-source contributions, and practical projects is key to staying competitive and mitigating the impact of hiring slowdowns or layoffs.`
  },
  {
    question: "How bad is the current job market?",
    answer: `While the narrative of the "bad job market" is influenced by recent layoffs and a general hiring slowdown, especially in tech, it's more nuanced. Data suggests the market isn't universally "bad" but rather highly selective. Companies are hiring strategically, leading to increased competition for many roles. The current IT job market in US is strong for specific skill sets, particularly those related to cloud and AI demand. Job seekers need to differentiate themselves with highly relevant, future-proof skills.`
  },
  {
    question: "How is the current IT job market in US?",
    answer: `The current IT job market in US is undergoing a transformation driven by cloud adoption and AI integration. There's a significant demand for cloud architects, AI/ML engineers, cybersecurity specialists, and data scientists. However, traditional IT roles may face oversaturation and increased competition. The tech hiring slowdown has made companies more stringent in their requirements, emphasizing practical experience and specialized certifications. Remote work trends continue to shape geographic distribution of opportunities.`
  },
];

const jsonLdSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_CONTENT.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout 
	title="US Tech Job Market Intelligence | Live Dashboard 2026"
	description="Live visual intelligence of the US tech job market. Track hiring momentum, AI demand, layoff pressure, and salary trends."
>
	<Navbar />
	
	<main class="bg-black min-h-screen text-white selection:bg-brand-cyan/30">
		
		<!-- 1. HERO MARKET STATUS -->
		<section class="relative pt-32 pb-16 lg:pt-48 lg:pb-24 overflow-hidden border-b border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
				
				<div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
					<div class="max-w-3xl">
						<div class="flex items-center gap-3 mb-6">
							<div class={`px-3 py-1 rounded-full ${statusBg} border border-white/10 flex items-center gap-2`}>
								<span class="relative flex h-2 w-2">
									<span class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${statusColor.replace('text-', 'bg-')}`}></span>
									<span class={`relative inline-flex rounded-full h-2 w-2 ${statusColor.replace('text-', 'bg-')}`}></span>
								</span>
								<span class={`text-[10px] font-mono font-bold uppercase tracking-wider ${statusColor}`}>US Tech Market {marketStatus}</span>
							</div>
							<span class="text-[10px] font-mono text-muted-foreground uppercase tracking-wider">Updated {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
						</div>

						<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-[0.9] text-balance">
							The State of the <br/>
							<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white/90 to-white/40 italic">US Tech Labor Market</span>
						</h1>
						
						<p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl">
							Live market briefing aggregating real-time hiring velocity, layoff pressure, and compensation benchmarks across 50+ US tech hubs.
						</p>
					</div>

					<div class="flex flex-col gap-2 p-6 rounded-2xl bg-white/[0.02] border border-white/10 min-w-[240px]">
						<span class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">Market Confidence</span>
						<div class="flex items-end gap-3">
							<span class="text-4xl font-bold tracking-tighter">{(hiringVelocity * 10).toFixed(0)}<span class="text-lg text-muted-foreground">/100</span></span>
							<div class="flex-1 h-2 bg-white/5 rounded-full overflow-hidden mb-2">
								<div class="h-full bg-brand-cyan transition-all duration-1000" style={`width: ${hiringVelocity * 10}%`}></div>
							</div>
						</div>
						<p class="text-[10px] text-muted-foreground italic">Based on hiring volume vs historical baseline.</p>
					</div>
				</div>

				<!-- Dashboard Snapshot Grid -->
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
					<MarketInsightCard 
						title="Hiring Momentum" 
						value={`${marketPulse.totalJobs}`} 
						subValue="open roles"
						trend={{ value: `${((marketPulse.recentJobs / marketPulse.totalJobs) * 100).toFixed(1)}% new`, isUp: true }}
					>
						<MiniChart data={hiringTrends.map(t => t.value)} color="#50e3c2" />
					</MarketInsightCard>

					<MarketInsightCard 
						title="Layoff Pressure" 
						value={`${recentLayoffsCount}`} 
						subValue="impacted"
						type={recentLayoffsCount > 500 ? 'negative' : 'default'}
						trend={{ value: `${layoffTrend}%`, isUp: recentLayoffsCount < previousLayoffsCount }}
					>
						<div class="mt-4 flex gap-1 h-2">
							{recentLayoffs.slice(0, 12).map(l => (
								<div 
									class={`flex-1 rounded-sm ${l.layoffs_count > 100 ? 'bg-brand-magenta' : 'bg-white/20'}`}
									title={`${l.company}: ${l.layoffs_count}`}
								></div>
							))}
						</div>
					</MarketInsightCard>

					<MarketInsightCard 
						title="AI Hiring Share" 
						value={`${aiMomentum.percentage}%`} 
						subValue="of listings"
						type="positive"
						trend={{ value: "Expanding", isUp: true, neutral: true }}
					>
						<div class="mt-4 h-2 w-full bg-white/5 rounded-full overflow-hidden">
							<div class="h-full bg-brand-cyan shadow-[0_0_10px_rgba(80,227,194,0.5)]" style={`width: ${aiMomentum.percentage}%`}></div>
						</div>
					</MarketInsightCard>

					<MarketInsightCard 
						title="Salary Climate" 
						value={formatSalary(marketPulse.avgSalary)} 
						subValue="median base"
						trend={{ value: "Stable", isUp: true, neutral: true }}
					>
						<div class="mt-4 flex items-end justify-between h-8 gap-1">
							{[40, 60, 45, 70, 55, 80, 75].map(h => (
								<div class="flex-1 bg-white/10 rounded-t-sm" style={`height: ${h}%`}></div>
							))}
						</div>
					</MarketInsightCard>
				</div>
			</div>

			<!-- Decorative background elements -->
			<div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-blue/10 rounded-full blur-[120px] -z-10 pointer-events-none translate-x-1/3 -translate-y-1/3"></div>
			<div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-brand-magenta/5 rounded-full blur-[100px] -z-10 pointer-events-none -translate-x-1/2 translate-y-1/2"></div>
		</section>

		<!-- 2. AI MARKET BRIEFING (TICKER STYLE) -->
		<section class="py-12 bg-black border-b border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col lg:flex-row gap-8 lg:items-center">
					<div class="shrink-0 flex items-center gap-3">
						<div class="px-2 py-1 rounded bg-brand-cyan/10 border border-brand-cyan/20 text-[10px] font-mono font-bold text-brand-cyan uppercase">Gemini Insight</div>
						<span class="text-xs font-bold uppercase tracking-widest text-white/40">Market Intelligence Briefing</span>
					</div>
					<div class="grid md:grid-cols-3 gap-8 flex-1">
						{aiIntelligence.intelligence_briefing.slice(0, 3).map((insight: string) => (
							<p class="text-sm text-muted-foreground leading-relaxed border-l border-white/10 pl-4 py-1 italic">
								"{insight}"
							</p>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- 3. VISUAL INTELLIGENCE GRID -->
		<section class="py-24 relative overflow-hidden">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-12 gap-12">
					
					<!-- Left: Deeper Insights -->
					<div class="lg:col-span-8 space-y-12">
						
						<!-- Intelligence Previews -->
						<div class="grid sm:grid-cols-2 gap-6">
							<a href="/roles" class="group p-6 rounded-2xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all">
								<div class="flex justify-between items-start mb-4">
									<div class="h-10 w-10 rounded-lg bg-brand-blue/10 flex items-center justify-center text-brand-blue group-hover:scale-110 transition-transform">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
									</div>
									<span class="text-xs font-mono text-brand-cyan">→ Explore Roles</span>
								</div>
								<h3 class="text-xl font-bold mb-2">Roles & Demand</h3>
								<p class="text-sm text-muted-foreground mb-4">AI Infrastructure and Backend engineering remain the strongest hiring categories this month.</p>
								<div class="flex flex-wrap gap-2">
									{topSkills.slice(0, 3).map(s => <span class="px-2 py-0.5 rounded-full bg-white/5 text-[10px] text-muted-foreground">#{s.skill}</span>)}
								</div>
							</a>

							<a href="/layoffs" class="group p-6 rounded-2xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all">
								<div class="flex justify-between items-start mb-4">
									<div class="h-10 w-10 rounded-lg bg-brand-magenta/10 flex items-center justify-center text-brand-magenta group-hover:scale-110 transition-transform">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
									</div>
									<span class="text-xs font-mono text-brand-magenta">→ Explore Layoffs</span>
								</div>
								<h3 class="text-xl font-bold mb-2">Layoff Analysis</h3>
								<p class="text-sm text-muted-foreground mb-4">Recruiting and general support functions are facing the highest pressure across big tech.</p>
								<div class="flex items-center gap-2 text-[10px] font-mono text-muted-foreground uppercase">
									<span class="text-brand-magenta">High Volatility</span> • {recentLayoffsCount} impacted
								</div>
							</a>

							<a href="/skills" class="group p-6 rounded-2xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all">
								<div class="flex justify-between items-start mb-4">
									<div class="h-10 w-10 rounded-lg bg-brand-cyan/10 flex items-center justify-center text-brand-cyan group-hover:scale-110 transition-transform">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
									</div>
									<span class="text-xs font-mono text-brand-cyan">→ Explore Skills</span>
								</div>
								<h3 class="text-xl font-bold mb-2">Skill Intelligence</h3>
								<p class="text-sm text-muted-foreground mb-4">Kubernetes, Python, and TypeScript demand continues to rise despite broader market cooling.</p>
								<div class="w-full h-1 bg-white/5 rounded-full overflow-hidden mt-4">
									<div class="h-full bg-brand-cyan" style="width: 70%"></div>
								</div>
							</a>

							<a href="/salaries" class="group p-6 rounded-2xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all">
								<div class="flex justify-between items-start mb-4">
									<div class="h-10 w-10 rounded-lg bg-brand-amber/10 flex items-center justify-center text-brand-amber group-hover:scale-110 transition-transform">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
									</div>
									<span class="text-xs font-mono text-brand-amber">→ Explore Salaries</span>
								</div>
								<h3 class="text-xl font-bold mb-2">Salary Benchmarks</h3>
								<p class="text-sm text-muted-foreground mb-4">Compensation bands are compressing for mid-level roles, while senior specialists maintain leverage.</p>
								<div class="flex items-end gap-1 h-4">
									{[30, 50, 80, 40, 60, 90].map(h => <div class="flex-1 bg-brand-amber/40 rounded-t-[1px]" style={`height: ${h}%`}></div>)}
								</div>
							</a>
						</div>

						<!-- Geographic Momentum -->
						<div class="p-8 rounded-3xl border border-white/5 bg-white/[0.01]">
							<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-12">
								<div>
									<h2 class="text-2xl font-bold mb-2">Geographic Hiring Velocity</h2>
									<p class="text-sm text-muted-foreground">Concentration of active volume across top-tier US tech hubs.</p>
								</div>
								<a href="/cities" class="text-xs font-mono uppercase tracking-widest text-brand-cyan hover:underline">All Cities →</a>
							</div>

							<div class="space-y-6">
								{topCities.map(city => {
									const maxJobs = Math.max(...topCities.map(c => c.job_count));
									const width = (city.job_count / maxJobs) * 100;
									return (
										<div class="group">
											<div class="flex justify-between items-end mb-3">
												<span class="text-sm font-bold group-hover:text-brand-cyan transition-colors">{city.city}</span>
												<span class="text-xs font-mono text-muted-foreground">{city.job_count} active roles</span>
											</div>
											<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
												<div class="h-full bg-brand-cyan transition-all duration-1000 group-hover:bg-white" style={`width: ${width}%`}></div>
											</div>
										</div>
									)
								})}
							</div>
						</div>
					</div>

					<!-- Right: Meta Data & Market Pulse -->
					<div class="lg:col-span-4 space-y-8">
						
						<!-- Market Confidence Card -->
						<div class="p-6 rounded-2xl border border-brand-cyan/20 bg-brand-cyan/[0.03]">
							<h3 class="text-sm font-mono text-brand-cyan uppercase tracking-widest mb-4">Junior Market Status</h3>
							<div class="flex items-baseline gap-2 mb-2">
								<span class="text-3xl font-bold">{juniorDifficulty.percentage}%</span>
								<span class="text-xs text-muted-foreground font-medium">Hiring Volume</span>
							</div>
							<p class="text-xs text-muted-foreground leading-relaxed mb-4">
								Junior and entry-level hiring remains highly constrained. Oversaturation in entry-level applicant pools is driving extreme selectivity.
							</p>
							<div class="flex items-center gap-2 text-[10px] font-mono text-brand-magenta font-bold uppercase tracking-tighter">
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
								High Competition
							</div>
						</div>

						<!-- Remote Work Status -->
						<div class="p-6 rounded-2xl border border-white/10 bg-white/[0.02]">
							<h3 class="text-sm font-mono text-muted-foreground uppercase tracking-widest mb-4">Remote Flexibility</h3>
							<div class="flex items-baseline gap-2 mb-4">
								<span class="text-3xl font-bold">{remoteTrend.percentage}%</span>
								<span class="text-xs text-muted-foreground font-medium">Remote Options</span>
							</div>
							<div class="space-y-3">
								<div class="flex justify-between text-[10px] font-mono text-muted-foreground uppercase">
									<span>On-Site / Hybrid</span>
									<span>Remote</span>
								</div>
								<div class="flex h-2 w-full rounded-full overflow-hidden">
									<div class="h-full bg-white/10" style={`width: ${100 - remoteTrend.percentage}%`}></div>
									<div class="h-full bg-brand-cyan" style={`width: ${remoteTrend.percentage}%`}></div>
								</div>
							</div>
						</div>

						<!-- Trust & Sources -->
						<div class="p-6 rounded-2xl border border-white/5 bg-white/[0.01]">
							<h3 class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest mb-6">Data Transparency</h3>
							<div class="space-y-6">
								<div class="flex gap-4">
									<div class="shrink-0 h-8 w-8 rounded bg-white/5 flex items-center justify-center text-muted-foreground">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 0 1 0-4h14a2 2 0 0 1 2 2v2"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
									</div>
									<div>
										<h4 class="text-xs font-bold text-white mb-1">Live Pipeline</h4>
										<p class="text-[10px] text-muted-foreground leading-relaxed">Aggregated from 12+ sources including Greenhouse, Ashby, and Indeed.</p>
									</div>
								</div>
								<div class="flex gap-4">
									<div class="shrink-0 h-8 w-8 rounded bg-white/5 flex items-center justify-center text-muted-foreground">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
									</div>
									<div>
										<h4 class="text-xs font-bold text-white mb-1">AI Verified</h4>
										<p class="text-[10px] text-muted-foreground leading-relaxed">Intelligence briefings generated by Google Gemini 2.0 Flash.</p>
									</div>
								</div>
								<div class="flex gap-4">
									<div class="shrink-0 h-8 w-8 rounded bg-white/5 flex items-center justify-center text-muted-foreground">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
									</div>
									<div>
										<h4 class="text-xs font-bold text-white mb-1">Weekly Snapshots</h4>
										<p class="text-[10px] text-muted-foreground leading-relaxed">Historical trends captured every Sunday for long-term drift analysis.</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- 4. PROFESSIONAL ANALYSIS -->
		<section class="py-24 bg-white/[0.02] border-y border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="max-w-4xl">
					<div class="flex items-center gap-3 mb-8">
						<div class="h-px flex-1 bg-white/10"></div>
						<span class="text-[10px] font-mono text-brand-cyan uppercase tracking-[0.2em] font-bold">In-Depth Analysis</span>
						<div class="h-px flex-1 bg-white/10"></div>
					</div>
					
