---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getSalaryBenchmarks } from '../../services/jobService';
import { getRegion, getRegionConfig } from '../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const dbSalaries = await getSalaryBenchmarks(region);

const isINR = regionConfig.currency.format === 'INR';

const salaryData = dbSalaries.length > 0
  ? dbSalaries.map(s => ({
      role: s.role,
      avgMin: isINR ? (s.avg_min / 100000).toFixed(1) : (s.avg_min / 1000).toFixed(0),
      avgMax: isINR ? (s.avg_max / 100000).toFixed(1) : (s.avg_max / 1000).toFixed(0),
      avgMedian: isINR 
        ? (((s.avg_min + s.avg_max) / 2) / 100000).toFixed(1)
        : (((s.avg_min + s.avg_max) / 2) / 1000).toFixed(0),
      unit: isINR ? 'L' : 'k'
    }))
  : [];
---

<Layout 
  title={`${regionConfig.name} Tech Salary Trends 2026 | Tech Compensation Benchmarks`}
  description={`Explore current tech salary trends in the ${regionConfig.name} tech job market for 2026. Get data-driven insights on compensation and pay scales.`}
  region={region}
>
  <script type="application/ld+json" define:vars={{ region, regionConfig }}>
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Tech Salaries in ${regionConfig.name} 2026 | Tech Pay Scales`,
    "description": `How much do tech professionals make in the current ${regionConfig.name} tech job market? Explore average salaries, compensation ranges, and trends for 2026.`,
    "url": `https://techjobmarket.com/${region}/salaries`,
    "mainEntity": {
      "@type": "Dataset",
      "name": `${regionConfig.name} Tech Salary Benchmarks Dataset`,
      "description": `A dataset of average annual base salary ranges (${regionConfig.currency.code}) by tech role across major ${regionConfig.name} tech hubs.`,
      "creator": {
        "@type": "Organization",
        "name": "TechJobMarket"
      },
      "url": `https://techjobmarket.com/${region}/salaries`,
      "keywords": ["tech salaries", "pay scales", "compensation trends", `${regionConfig.name} tech salaries`]
    }
  }
  </script>
  <Navbar region={region} />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">{regionConfig.labels.salaryBenchmarks}</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Average annual base salary ranges ({regionConfig.currency.label}) by role across major {regionConfig.name} tech hubs.</p>
      </div>

      <!-- Search Section -->
      <div class="mb-12">
        <div class="relative max-w-md">
          <input 
            type="text" 
            id="roleSearch"
            placeholder="Search roles (e.g. Frontend Developer)..." 
            class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white focus:outline-none focus:border-brand-cyan/50 transition-colors pl-10"
          />
          <svg class="absolute left-3 top-3.5 h-4 w-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
      
      <!-- Desktop Table -->
      <div class="hidden md:block overflow-x-auto rounded-xl border border-white/10 bg-card">
        <table class="w-full border-collapse" id="salaryTable">
          <thead>
            <tr class="border-b border-white/10 text-left bg-white/[0.02]">
              <th class="py-6 px-6 text-sm font-mono text-muted-foreground uppercase tracking-widest">Job Role</th>
              <th class="py-6 px-6 text-sm font-mono text-muted-foreground uppercase tracking-widest">Avg. Min</th>
              <th class="py-6 px-6 text-sm font-mono text-muted-foreground uppercase tracking-widest">Avg. Max</th>
              <th class="py-6 px-6 text-sm font-mono text-muted-foreground uppercase tracking-widest text-brand-cyan">Estimated Median</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {salaryData.length > 0 ? salaryData.map(item => (
              <tr class="group hover:bg-white/[0.02] transition-colors salary-row" data-role={item.role.toLowerCase()}>
                <td class="py-6 px-6">
                  <span class="text-lg font-bold text-white group-hover:text-brand-cyan transition-colors">{item.role}</span>
                </td>
                <td class="py-6 px-6 text-white/70">{regionConfig.currency.symbol}{item.avgMin}{item.unit}</td>
                <td class="py-6 px-6 text-white/70">{regionConfig.currency.symbol}{item.avgMax}{item.unit}</td>
                <td class="py-6 px-6">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-cyan/10 text-brand-cyan">
                    {regionConfig.currency.symbol}{item.avgMedian}{item.unit}
                  </span>
                </td>
              </tr>
            )) : (
              <tr>
                <td colspan="4" class="py-12 text-center text-muted-foreground italic">
                  No salary data available yet. Pipeline is scraping current {regionConfig.name} tech job salaries.
                </td>
              </tr>
            )}
          </tbody>

        </table>
      </div>

      <!-- Mobile Condensed List -->
      <div id="salaryCards" class="divide-y divide-white/5 md:hidden border-t border-white/10">
        {salaryData.length > 0 ? salaryData.map(item => (
          <div class="py-4 px-2 hover:bg-white/[0.02] transition-colors salary-row-mobile flex items-center justify-between gap-4" data-role={item.role.toLowerCase()}>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-bold text-white mb-1 truncate">{item.role}</h3>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-1">
                  <span class="text-[9px] text-muted-foreground uppercase font-mono">Min:</span>
                  <span class="text-xs font-mono text-white/70">{regionConfig.currency.symbol}{item.avgMin}{item.unit}</span>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-[9px] text-muted-foreground uppercase font-mono">Max:</span>
                  <span class="text-xs font-mono text-white/70">{regionConfig.currency.symbol}{item.avgMax}{item.unit}</span>
                </div>
              </div>
            </div>
            
            <div class="text-right shrink-0">
              <span class="block text-[9px] text-brand-cyan uppercase font-mono mb-0.5 tracking-tighter">Est. Median</span>
              <span class="text-sm font-mono font-bold text-brand-cyan">{regionConfig.currency.symbol}{item.avgMedian}{item.unit}</span>
            </div>
          </div>
        )) : (
          <div class="py-12 text-center text-muted-foreground italic">
            No salary data available yet.
          </div>
        )}
      </div>

      {salaryData.length < 5 && salaryData.length > 0 && (
        <p class="mt-4 text-xs text-brand-magenta font-mono">
          ⚠️ Low confidence indicator: Limited data points for certain roles.
        </p>
      )}

      <script>
        const searchInput = document.getElementById('roleSearch');
        const rows = document.querySelectorAll('.salary-row');
        const mobileRows = document.querySelectorAll('.salary-row-mobile');

        searchInput?.addEventListener('input', (e) => {
          const term = (e.target as HTMLInputElement).value.toLowerCase();
          
          rows.forEach(row => {
            const role = row.getAttribute('data-role') || '';
            (row as HTMLElement).style.display = role.includes(term) ? '' : 'none';
          });

          mobileRows.forEach(row => {
            const role = row.getAttribute('data-role') || '';
            (row as HTMLElement).style.display = role.includes(term) ? '' : 'none';
          });
        });
      </script>

      <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 rounded-2xl border border-white/10 bg-card">
          <h3 class="text-xl font-bold text-white mb-4">Stock Options & RSUs</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            In 2026, many {regionConfig.name} tech companies are re-evaluating compensation. While major public companies continue to offer generous RSUs with 4-year vesting, early-stage startups are increasingly relying on higher base salaries or quarterly performance-linked bonuses to remain competitive.
          </p>
        </div>
        <div class="p-8 rounded-2xl border border-white/10 bg-card">
          <h3 class="text-xl font-bold text-white mb-4">The "GenAI Premium"</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">
            Engineers with proven experience in custom model training or RAG-at-scale are commanding a significant premium over traditional full-stack roles. We've seen "Talent Wars" in major hubs resulting in substantial base salary increases for senior AI architects.
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
