---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getSkillIntelligence } from '../../../services/outlookService';
import { getRegion, getRegionConfig } from '../../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const { skill } = Astro.params;
const decodedSkill = decodeURIComponent(skill || '');
const intelligence = await getSkillIntelligence(decodedSkill, region);

if (!intelligence) {
  return Astro.redirect(`/${region}/skills`);
}

const statusColors = {
  Hot: 'bg-red-500/20 text-red-400 shadow-[0_0_10px_rgba(239,68,68,0.2)]',
  Rising: 'bg-green-500/20 text-green-400',
  Stable: 'bg-brand-cyan/20 text-brand-cyan',
  Legacy: 'bg-white/10 text-white/40',
};

const formatSalary = (num: number) => {
  if (regionConfig.currency.format === 'INR') {
    return `₹${(num / 100000).toFixed(1)}L`;
  }
  return `$${(num / 1000).toFixed(0)}k`;
};
---

<Layout 
  title={`${intelligence.skill} Demand & Salary in ${regionConfig.name} 2026 | Skill Intelligence`}
  description={`How in-demand is ${intelligence.skill}? Explore 2026 salary benchmarks, top hiring cities, and role distribution for ${intelligence.skill} in ${regionConfig.name}.`}
  region={region}
>
  <script type="application/ld+json" define:vars={{ region, regionConfig, intelligence, skill }}>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": `https://techjobmarket.com/${region}`
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Skills",
        "item": `https://techjobmarket.com/${region}/skills`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": intelligence.skill,
        "item": `https://techjobmarket.com/${region}/skill/${skill}`
      }
    ]
  }
  </script>

  <Navbar region={region} />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-muted-foreground">
          <li><a href={`/${region}`} class="hover:text-white transition-colors">Home</a></li>
          <li><span>/</span></li>
          <li><a href={`/${region}/skills`} class="hover:text-white transition-colors">Skills</a></li>
          <li><span>/</span></li>
          <li class="text-white font-medium">{intelligence.skill}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Stats -->
        <div class="lg:col-span-2 space-y-12">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <h1 class="text-4xl font-bold text-white tracking-tight">{intelligence.skill} Skill Analytics</h1>
              <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase ${statusColors[intelligence.status]}`}>
                {intelligence.status}
              </span>
            </div>
            <p class="text-xl text-muted-foreground leading-relaxed">
              Deep dive into <strong>demand for ${intelligence.skill}</strong> in the ${regionConfig.name} tech market. {intelligence.insight}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Job Mentions</span>
              <p class="text-3xl font-bold text-white mt-2">{intelligence.jobCount}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">YoY Growth</span>
              <p class={`text-3xl font-bold mt-2 ${intelligence.growthPercentage >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                {intelligence.growthPercentage}%
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Skill Premium</span>
              <p class="text-3xl font-bold text-white mt-2">
                {formatSalary(intelligence.avgSalary)}
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-white mb-6">Technical Demand Analysis: {intelligence.skill}</h2>
            <div class="prose prose-invert max-w-none">
              <p>
                In the <strong>current job market for software engineers</strong> and tech professionals, <strong>${intelligence.skill}</strong> has established itself as a ${intelligence.status.toLowerCase()} requirement. 
                Our data shows that <strong>${intelligence.skill}</strong> is currently appearing in {intelligence.jobCount} active job listings across ${regionConfig.name}.
              </p>
              <p>
                The financial return for <strong>${intelligence.skill}</strong> proficiency is significant, with an average base salary of {formatSalary(intelligence.avgSalary)} in ${regionConfig.name}. 
                Demand is particularly high for roles such as <strong>{intelligence.topRoles.map(r => r.role).join(', ')}</strong>.
              </p>
              <p>
                Geographically, the strongest demand for <strong>${intelligence.skill}</strong> talent is found in 
                <strong>{intelligence.topCities.map(c => c.city).join(', ')}</strong>. 
                Professionals with this skill set are currently seeing a {intelligence.growthPercentage}% {intelligence.growthPercentage >= 0 ? 'increase' : 'shift'} in opportunities compared to previous cycles.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="rounded-xl border border-brand-cyan/20 bg-brand-cyan/5 p-8">
            <h3 class="text-lg font-bold text-white mb-4">Top Roles Requiring {intelligence.skill}</h3>
            <ul class="space-y-4">
              {intelligence.topRoles.map(r => (
                <li class="flex items-center justify-between">
                  <a href={`/${region}/role/${encodeURIComponent(r.role)}`} class="text-muted-foreground hover:text-brand-cyan transition-colors">{r.role}</a>
                  <span class="text-xs font-mono text-white/40">{r.count}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-xl border border-white/10 bg-card p-8">
            <h3 class="text-lg font-bold text-white mb-4">Top Hubs for {intelligence.skill}</h3>
            <ul class="space-y-4">
              {intelligence.topCities.map(c => (
                <li class="flex items-center justify-between">
                  <a href={`/${region}/city/${encodeURIComponent(c.city)}`} class="text-muted-foreground hover:text-brand-cyan transition-colors">{c.city}</a>
                  <span class="text-xs font-mono text-white/40">{c.count}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="p-6 rounded-xl bg-brand-magenta/10 border border-brand-magenta/20">
             <h4 class="font-bold text-white mb-2">Confidence Indicator</h4>
             <p class="text-xs text-muted-foreground">
               Based on real-time extraction from ${intelligence.jobCount} job descriptions. Normalized using AI tagging for accuracy.
             </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
