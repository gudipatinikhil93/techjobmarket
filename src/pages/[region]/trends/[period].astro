---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getHistoricalTrends } from '../../../services/jobService';
import { getRegion, getRegionConfig } from '../../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const { period } = Astro.params;
const trends = await getHistoricalTrends(region, period || '');

if (!trends) {
  return Astro.redirect(`/${region}/trends`);
}

// Format period for display (e.g., 2026-06 -> June 2026)
const [year, month] = (period || '').split('-');
const date = new Date(parseInt(year), parseInt(month) - 1);
const formattedPeriod = date.toLocaleString('default', { month: 'long', year: 'numeric' });

const formatSalary = (num: number) => {
  if (regionConfig.currency.format === 'INR') {
    return `₹${(num / 100000).toFixed(1)}L`;
  }
  return `$${(num / 1000).toFixed(0)}k`;
};
---

<Layout 
  title={`${regionConfig.name} Tech Job Market Archive: ${formattedPeriod} | TechJobMarket`}
  description={`Historical tech job market intelligence for ${formattedPeriod} in ${regionConfig.name}. Review salary trends, top roles, and hiring velocity from this period.`}
  region={region}
>
  <Navbar region={region} />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-muted-foreground">
          <li><a href={`/${region}`} class="hover:text-white transition-colors">Home</a></li>
          <li><span>/</span></li>
          <li><a href={`/${region}/trends`} class="hover:text-white transition-colors">Trends</a></li>
          <li><span>/</span></li>
          <li class="text-white font-medium">{formattedPeriod} Archive</li>
        </ol>
      </nav>

      <div class="mb-12">
        <h1 class="text-4xl font-bold text-white mb-4">Market Intelligence Archive: {formattedPeriod}</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Historical snapshot of tech hiring across {regionConfig.name} during {formattedPeriod}.</p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-white/10 bg-card">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-white/10 bg-white/5">
              <th class="px-6 py-4 text-xs font-mono uppercase tracking-widest text-muted-foreground">Technical Role</th>
              <th class="px-6 py-4 text-xs font-mono uppercase tracking-widest text-muted-foreground">Job Volume (Peak)</th>
              <th class="px-6 py-4 text-xs font-mono uppercase tracking-widest text-muted-foreground">Median Salary Range</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {trends.map(role => (
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-4">
                  <a href={`/${region}/role/${encodeURIComponent(role.role)}`} class="font-bold text-white hover:text-brand-cyan transition-colors">{role.role}</a>
                </td>
                <td class="px-6 py-4 font-mono text-muted-foreground">
                  {role.jobCount}
                </td>
                <td class="px-6 py-4 font-mono text-muted-foreground">
                  {formatSalary(role.avgSalaryMin)} - {formatSalary(role.avgSalaryMax)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      <div class="mt-12 p-8 rounded-2xl bg-brand-cyan/5 border border-brand-cyan/10">
        <h3 class="text-xl font-bold text-white mb-4">Archive Methodology</h3>
        <p class="text-muted-foreground leading-relaxed">
          This archive is generated from weekly snapshots captured during {formattedPeriod}. Job volume reflects the peak number of active listings observed for each role. Salary ranges are aggregated averages from listings that provided compensation data during this period.
        </p>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
