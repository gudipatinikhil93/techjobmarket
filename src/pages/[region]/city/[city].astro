---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCityIntelligence } from '../../../services/outlookService';
import { getRegion, getRegionConfig } from '../../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const { city } = Astro.params;
const decodedCity = decodeURIComponent(city || '');
const intelligence = await getCityIntelligence(decodedCity, region);

if (!intelligence) {
  return Astro.redirect(`/${region}/cities`);
}

const statusColors = {
  Booming: 'bg-green-500/20 text-green-400',
  Steady: 'bg-brand-cyan/20 text-brand-cyan',
  Shifting: 'bg-orange-500/20 text-orange-400',
  Cooling: 'bg-brand-magenta/20 text-brand-magenta',
};

const formatSalary = (num: number) => {
  if (regionConfig.currency.format === 'INR') {
    return `₹${(num / 100000).toFixed(1)}L`;
  }
  return `$${(num / 1000).toFixed(0)}k`;
};
---

<Layout 
  title={`Tech Job Market in ${intelligence.city}, ${regionConfig.name} 2026 | Salary & Trends`}
  description={`Discover the current job market trends in ${intelligence.city}. Analyze tech salaries, top hiring roles, and in-demand skills in ${intelligence.city}, ${regionConfig.name}.`}
  region={region}
>
  <script type="application/ld+json" define:vars={{ region, regionConfig, intelligence, city }}>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": `https://techjobmarket.com/${region}`
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Cities",
        "item": `https://techjobmarket.com/${region}/cities`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": intelligence.city,
        "item": `https://techjobmarket.com/${region}/city/${city}`
      }
    ]
  }
  </script>

  <Navbar region={region} />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-muted-foreground">
          <li><a href={`/${region}`} class="hover:text-white transition-colors">Home</a></li>
          <li><span>/</span></li>
          <li><a href={`/${region}/cities`} class="hover:text-white transition-colors">Cities</a></li>
          <li><span>/</span></li>
          <li class="text-white font-medium">{intelligence.city}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Stats -->
        <div class="lg:col-span-2 space-y-12">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <h1 class="text-4xl font-bold text-white tracking-tight">{intelligence.city} Tech Hub</h1>
              <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase ${statusColors[intelligence.status]}`}>
                {intelligence.status}
              </span>
            </div>
            <p class="text-xl text-muted-foreground leading-relaxed">
              Real-time intelligence on the <strong>tech job market in ${intelligence.city}</strong>, ${regionConfig.name}. {intelligence.insight}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Active Tech Roles</span>
              <p class="text-3xl font-bold text-white mt-2">{intelligence.jobCount}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Market Velocity</span>
              <p class={`text-3xl font-bold mt-2 ${intelligence.growthPercentage >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                {intelligence.growthPercentage}%
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Avg Compensation</span>
              <p class="text-3xl font-bold text-white mt-2">
                {formatSalary(intelligence.avgSalary)}
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-white mb-6">Market Deep Dive: {intelligence.city}</h2>
            <div class="prose prose-invert max-w-none">
              <p>
                The <strong>current job market in ${intelligence.city}</strong> is showing a 
                {intelligence.status.toLowerCase()} trend. As one of the key tech centers in ${regionConfig.name}, 
                ${intelligence.city} continues to attract significant talent and investment, particularly in 
                roles like <strong>{intelligence.topRoles.map(r => r.role).join(', ')}</strong>.
              </p>
              <p>
                Salary benchmarks in <strong>{intelligence.city}</strong> average around {formatSalary(intelligence.avgSalary)} base, 
                though senior specialized roles in AI and Cloud can command significantly higher premiums. 
                The most in-demand skills for local employers include <strong>{intelligence.topSkills.map(s => s.skill).slice(0, 3).join(', ')}</strong>.
              </p>
              <p>
                With a market velocity of {intelligence.growthPercentage}%, hiring managers in {intelligence.city} are 
                {intelligence.growthPercentage > 0 ? 'actively expanding' : 'selectively filling'} technical teams. 
                Professionals looking for opportunities here should prioritize building proficiency in 
                {intelligence.topSkills[0]?.skill} and {intelligence.topSkills[1]?.skill}.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="rounded-xl border border-brand-cyan/20 bg-brand-cyan/5 p-8">
            <h3 class="text-lg font-bold text-white mb-4">Top Roles in {intelligence.city}</h3>
            <ul class="space-y-4">
              {intelligence.topRoles.map(r => (
                <li class="flex items-center justify-between">
                  <a href={`/${region}/role/${encodeURIComponent(r.role)}`} class="text-muted-foreground hover:text-brand-cyan transition-colors">{r.role}</a>
                  <span class="text-xs font-mono text-white/40">{r.count}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-xl border border-white/10 bg-card p-8">
            <h3 class="text-lg font-bold text-white mb-4">Hub Skill Focus</h3>
            <div class="flex flex-wrap gap-2">
              {intelligence.topSkills.map(s => (
                <a href={`/${region}/skill/${encodeURIComponent(s.skill)}`} class="px-3 py-1 rounded-lg border border-white/10 bg-white/5 text-sm text-white hover:border-brand-cyan transition-colors">
                  {s.skill}
                </a>
              ))}
            </div>
          </div>
          
          <div class="p-6 rounded-xl bg-brand-magenta/10 border border-brand-magenta/20">
             <h4 class="font-bold text-white mb-2">Source Transparency</h4>
             <p class="text-xs text-muted-foreground">
               Aggregated from ${intelligence.jobCount} live job listings in ${intelligence.city}. Data includes direct career portals and major job boards.
             </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
