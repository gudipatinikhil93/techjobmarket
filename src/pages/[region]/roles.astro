---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import MarketInsightCard from '../../components/MarketInsightCard.astro';
import MiniChart from '../../components/MiniChart.astro';
import TrendHighlight from '../../components/TrendHighlight.astro';
import ComparativeAnalytics from '../../components/ComparativeAnalytics.astro';
import IntelligenceCard from '../../components/IntelligenceCard.astro';
import { getMarketOutlook } from '../../services/outlookService';
import { 
  getMarketPulse, 
  getRemoteTrend, 
  getAIHiringMomentum, 
  getTrendingRoles, 
  getDecliningRoles,
  getSalaryBenchmarks,
  getWeeklyMovers
} from '../../services/jobService';
import { getRegion, getRegionConfig } from '../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);


// Fetch all data in parallel for performance
const [
  allRoles, 
  marketPulse, 
  remoteTrend, 
  aiMomentum, 
  trendingRoles, 
  decliningRoles,
  salaryBenchmarks,
  weeklyMovers
] = await Promise.all([
  getMarketOutlook(region),
  getMarketPulse(region),
  getRemoteTrend(region),
  getAIHiringMomentum(region),
  getTrendingRoles(region),
  getDecliningRoles(region),
  getSalaryBenchmarks(region),
  getWeeklyMovers(region, 'role')
]);

// Filter out extreme noise
const displayRoles = allRoles.filter(r => r.jobCount > 0);

// Sort for curated sections
const topHiring = [...displayRoles].sort((a, b) => b.jobCount - a.jobCount).slice(0, 4);

// roleComparison logic for ComparativeAnalytics
const roleComparison = topHiring.slice(0, 2).map(role => ({
  name: role.role,
  metrics: [
    { label: "Hiring Volume", value: `${role.jobCount} roles`, score: Math.min(100, (role.jobCount / 50) * 100) },
    { label: "Growth", value: `${role.growthPercentage}%`, score: Math.min(100, (role.growthPercentage + 20) * 2) },
    { label: "Salary Cap", value: `~${(role.avgSalaryMax / (region === 'india' ? 100000 : 1000)).toFixed(0)}${region === 'india' ? 'L' : 'k'}`, score: Math.min(100, (role.avgSalaryMax / (region === 'us' ? 250000 : 4500000)) * 100) }
  ]
}));

const fastestGrowing = trendingRoles.slice(0, 4);
const highestPaying = salaryBenchmarks.slice(0, 4);
const riskAreas = decliningRoles.slice(0, 4);

const formatSalary = (min: number, max: number) => {
  if (!min || !max) return 'Market Rate';
  if (regionConfig.currency.format === 'INR') {
    return `₹${(min/100000).toFixed(1)}L - ₹${(max/100000).toFixed(1)}L`;
  }
  return `$${(min/1000).toFixed(0)}k - $${(max/1000).toFixed(0)}k`;
};

const getStatusColor = (status: string) => {
  switch (status) {
    case 'Growing': return 'text-brand-cyan bg-brand-cyan/10 border-brand-cyan/20';
    case 'Declining': return 'text-brand-magenta bg-brand-magenta/10 border-brand-magenta/20';
    case 'Oversaturated': return 'text-orange-400 bg-orange-400/10 border-orange-400/20';
    default: return 'text-brand-blue bg-brand-blue/10 border-brand-blue/20';
  }
};
---

<Layout 
  title={`${regionConfig.name} Tech Job Market Roles & Hiring Intelligence 2026 | TechJobMarket`}
  description={`${regionConfig.name} tech hiring intelligence dashboard. Real-time data on role demand, AI hiring momentum, remote trends, and salary benchmarks for 2026.`}
  region={region}
>
  <Navbar hideSearch={true} region={region} />
  
  <main class="py-12 md:py-20 bg-black min-h-screen cinematic-glow relative overflow-x-hidden">
    <!-- Atmospheric Layer -->
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] right-[-10%] w-[60%] h-[60%] bg-brand-cyan/5 rounded-full blur-[140px] animate-pulse-slow"></div>
      <div class="absolute bottom-[10%] left-[-10%] w-[50%] h-[50%] bg-brand-blue/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Section 1: Hero / Summary -->
      <div class="mb-16">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-10">
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 mb-4">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-cyan opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-cyan"></span>
              </span>
              <span class="text-[10px] font-mono font-bold uppercase tracking-wider text-brand-cyan">Live Market Intelligence</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight">
              Role Hiring <span class="text-brand-cyan">Intelligence</span>
            </h1>
            <p class="text-muted-foreground text-lg leading-relaxed">
              Real-time analysis of the {regionConfig.name} tech workforce. Tracking demand shifts, compensation trajectories, and role-specific hiring signals across the entire market.
            </p>
          </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 mb-16">
          <div class="lg:col-span-1">
            <TrendHighlight 
              title="Role Velocity" 
              type="weekly" 
              movers={weeklyMovers.map(m => ({ name: m.entity_name, change: `${m.wow_growth}%`, isUp: m.wow_growth > 0 }))}
            />
          </div>
          <div class="lg:col-span-2">
            <ComparativeAnalytics 
              title="Role Head-to-Head" 
              category="Workforce Intelligence"
              entities={roleComparison}
            />
          </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 mb-16">
          <IntelligenceCard 
            title="Sourcing Signal"
            summary="Recruiters are moving from broad keyword searches to specific project-based skill verification."
            type="info"
            footer="Observation based on recruiter feedback loops."
          />
          <IntelligenceCard 
            title="Growth Pivot"
            summary="Cloud Infrastructure roles are pivoting towards GPU-optimized orchestration."
            type="positive"
            footer="Directly linked to GenAI infrastructure demand."
          />
          <IntelligenceCard 
            title="Saturation Alert"
            summary="Entry-level Frontend roles are seeing extreme applicant density (500:1)."
            type="warning"
            footer="Suggests high barrier to entry for generalists."
          />
        </div>

        <!-- Market Pulse Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
          <MarketInsightCard 
            title="Total Tracked Roles" 
            value={marketPulse.totalJobs.toLocaleString()} 
            type="info"
            subValue="Active Openings"
            trend={{ value: `${marketPulse.recentJobs}+`, isUp: true, neutral: true }}
          />
          <MarketInsightCard 
            title="Hiring Index" 
            value={marketPulse.hiringIndex.toFixed(1)} 
            subValue="/ 10.0 Scale"
            type={marketPulse.hiringIndex > 8 ? 'positive' : 'warning'}
            trend={{ value: marketPulse.hiringIndex > 8 ? 'Strong' : 'Steady', isUp: marketPulse.hiringIndex > 8 }}
          />
          <MarketInsightCard 
            title="AI Momentum" 
            value={`${aiMomentum.percentage}%`} 
            subValue="Role Share"
            type="positive"
            trend={{ value: "Surging", isUp: true }}
          />
          <MarketInsightCard 
            title="Remote Capacity" 
            value={`${remoteTrend.percentage}%`} 
            subValue="Work Flexibility"
            type="info"
            trend={{ value: "Stable", isUp: true, neutral: true }}
          />
        </div>
      </div>

      <!-- Section 2: Curated Role Insights -->
      <div class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">Market Leaders & Velocity</h2>
          <div class="h-[1px] flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
          <!-- Top Hiring Roles -->
          <div class="p-6 rounded-2xl glass-panel border-white/5 bg-white/[0.01] flex flex-col h-full">
            <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground mb-6 flex justify-between items-center">
              Top Hiring Roles
              <span class="w-1.5 h-1.5 rounded-full bg-brand-cyan"></span>
            </h3>
            <div class="space-y-4 flex-1">
              {topHiring.map(role => (
                <a href={`/${region}/role/${encodeURIComponent(role.role)}`} class="group block">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-bold text-white group-hover:text-brand-cyan transition-colors">{role.role}</span>
                    <span class="text-xs font-mono text-muted-foreground">{role.jobCount}</span>
                  </div>
                  <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full bg-brand-cyan/40 group-hover:bg-brand-cyan transition-all" style={`width: ${topHiring.length > 0 ? Math.min(100, (role.jobCount / topHiring[0].jobCount) * 100) : 0}%`}></div>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Fastest Growing -->
          <div class="p-6 rounded-2xl glass-panel border-white/5 bg-white/[0.01] flex flex-col h-full">
            <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground mb-6 flex justify-between items-center">
              Fastest Growing
              <span class="w-1.5 h-1.5 rounded-full bg-brand-cyan animate-pulse"></span>
            </h3>
            <div class="space-y-4 flex-1">
              {fastestGrowing.map(role => (
                <a href={`/${region}/role/${encodeURIComponent(role.role)}`} class="group block">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-bold text-white group-hover:text-brand-cyan transition-colors">{role.role}</span>
                    <span class="text-xs font-mono text-brand-cyan">+{role.growth_percentage}%</span>
                  </div>
                  <MiniChart data={[20, 35, 45, 30, 55, 70, 85]} color="#00f2ff" />
                </a>
              ))}
            </div>
          </div>

          <!-- Highest Paying -->
          <div class="p-6 rounded-2xl glass-panel border-white/5 bg-white/[0.01] flex flex-col h-full">
            <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground mb-6 flex justify-between items-center">
              Highest Paying
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span>
            </h3>
            <div class="space-y-4 flex-1">
              {highestPaying.map(role => (
                <a href={`/${region}/role/${encodeURIComponent(role.role)}`} class="group block">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-bold text-white group-hover:text-brand-cyan transition-colors">{role.role}</span>
                    <span class="text-xs font-mono text-white/70">${(role.avg_max/1000).toFixed(0)}k</span>
                  </div>
                  <div class="flex gap-0.5">
                    {Array.from({length: 12}).map((_, i) => (
                      <div class={`h-2 flex-1 rounded-sm ${i < 8 ? 'bg-brand-blue/30' : 'bg-white/5'}`}></div>
                    ))}
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Risk Areas -->
          <div class="p-6 rounded-2xl glass-panel border-white/5 bg-white/[0.01] flex flex-col h-full">
            <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground mb-6 flex justify-between items-center">
              Risk & Correction
              <span class="w-1.5 h-1.5 rounded-full bg-brand-magenta"></span>
            </h3>
            <div class="space-y-4 flex-1">
              {riskAreas.map(role => (
                <a href={`/${region}/role/${encodeURIComponent(role.role)}`} class="group block">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-bold text-white group-hover:text-brand-magenta transition-colors">{role.role}</span>
                    <span class="text-xs font-mono text-brand-magenta">{role.growth_percentage}%</span>
                  </div>
                  <MiniChart data={[80, 70, 60, 65, 50, 45, 30]} color="#ff0080" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Section 4: Full Roles Directory -->
      <div id="directory">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
          <div>
            <h2 class="text-2xl font-bold text-white mb-2">Role Directory</h2>
            <p class="text-sm text-muted-foreground">Search and filter the complete database of tech roles.</p>
          </div>
          
          <div class="flex items-center gap-3 w-full md:w-auto">
            <div class="relative flex-1 md:w-64">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <input 
                type="text" 
                id="roleSearch" 
                placeholder="Filter directory..." 
                class="w-full bg-white/5 border border-white/10 rounded-lg pl-10 pr-4 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-brand-cyan/50 transition-all backdrop-blur-sm"
              >
            </div>
            <select id="statusFilter" class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:border-brand-cyan/50 transition-all appearance-none cursor-pointer backdrop-blur-sm">
              <option value="all">All Trends</option>
              <option value="Growing">Growing</option>
              <option value="Stable">Stable</option>
              <option value="Oversaturated">Oversaturated</option>
              <option value="Declining">Declining</option>
            </select>
          </div>
        </div>

        <!-- Data Table (Desktop) -->
        <div class="hidden md:block rounded-xl border border-white/10 bg-white/[0.01] overflow-hidden glass-panel">
          <table class="w-full text-left text-sm whitespace-nowrap" id="rolesTable">
            <thead class="bg-white/[0.03] border-b border-white/10 text-xs font-mono uppercase tracking-wider text-muted-foreground">
              <tr>
                <th scope="col" class="px-6 py-4 font-medium cursor-pointer hover:text-white transition-colors" data-sort="role">Role / Domain <span class="sort-icon"></span></th>
                <th scope="col" class="px-6 py-4 font-medium cursor-pointer hover:text-white transition-colors" data-sort="outlook">Market Outlook <span class="sort-icon"></span></th>
                <th scope="col" class="px-6 py-4 font-medium cursor-pointer hover:text-white transition-colors" data-sort="salary">Avg Base Salary <span class="sort-icon"></span></th>
                <th scope="col" class="px-6 py-4 font-medium cursor-pointer hover:text-white transition-colors" data-sort="openings">Active Openings <span class="sort-icon">▼</span></th>
                <th scope="col" class="px-6 py-4 font-medium cursor-pointer hover:text-white transition-colors" data-sort="trend">Momentum <span class="sort-icon"></span></th>
                <th scope="col" class="px-6 py-4 font-medium hidden lg:table-cell">Primary Hub</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5 text-white/80" id="rolesBody">
              {displayRoles.map((role) => (
                <tr class="hover:bg-white/[0.02] transition-colors group cursor-pointer" onclick={`window.location.href='/${region}/role/${encodeURIComponent(role.role)}'`} data-role={role.role.toLowerCase()} data-status={role.status} data-jobcount={role.jobCount} data-salary={role.avgSalaryMin} data-growth={role.growthPercentage}>
                  <td class="px-6 py-4 font-bold text-white group-hover:text-brand-cyan transition-colors">{role.role}</td>
                  <td class="px-6 py-4">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase border ${getStatusColor(role.status)}`}>
                      {role.status}
                    </span>
                  </td>
                  <td class="px-6 py-4 font-mono">{formatSalary(role.avgSalaryMin, role.avgSalaryMax)}</td>
                  <td class="px-6 py-4 font-mono">{role.jobCount}</td>
                  <td class="px-6 py-4 font-mono">
                    <span class={role.growthPercentage > 0 ? 'text-brand-cyan' : role.growthPercentage < 0 ? 'text-brand-magenta' : 'text-white/50'}>
                      {role.growthPercentage > 0 ? '+' : ''}{role.growthPercentage}%
                    </span>
                  </td>
                  <td class="px-6 py-4 hidden lg:table-cell text-muted-foreground">{role.topCities[0] || 'Remote'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Condensed List -->
        <div id="rolesCards" class="divide-y divide-white/5 md:hidden border-t border-white/10">
          {displayRoles.map((role) => (
            <div 
              class="py-4 px-2 active:bg-white/[0.05] transition-colors cursor-pointer flex items-center justify-between gap-4"
              onclick={`window.location.href='/${region}/role/${encodeURIComponent(role.role)}'`}
              data-role={role.role.toLowerCase()} 
              data-status={role.status} 
              data-jobcount={role.jobCount} 
              data-salary={role.avgSalaryMin} 
              data-growth={role.growthPercentage}
            >
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-sm font-bold text-white truncate">{role.role}</h3>
                  <span class={`inline-flex items-center px-1.5 py-0.5 rounded-[4px] text-[9px] font-bold uppercase border ${getStatusColor(role.status)} shrink-0`}>
                    {role.status}
                  </span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="flex items-center gap-1">
                    <span class="text-[10px] text-muted-foreground font-mono">Growth:</span>
                    <span class={`text-[10px] font-mono font-bold ${role.growthPercentage > 0 ? 'text-brand-cyan' : role.growthPercentage < 0 ? 'text-brand-magenta' : 'text-white/50'}`}>
                      {role.growthPercentage > 0 ? '+' : ''}{role.growthPercentage}%
                    </span>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="text-[10px] text-muted-foreground font-mono">Openings:</span>
                    <span class="text-[10px] font-mono text-white/70">{role.jobCount}</span>
                  </div>
                </div>
              </div>
              
              <div class="text-right shrink-0">
                <span class="block text-[10px] text-muted-foreground uppercase font-mono mb-0.5 tracking-tighter">Est. Base</span>
                <span class="text-xs font-mono font-bold text-white">{formatSalary(role.avgSalaryMin, role.avgSalaryMax)}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Pagination / Load More Button -->
        <div class="mt-8 flex justify-center">
          <button id="loadMore" class="px-6 py-2 rounded-lg bg-white/5 border border-white/10 text-sm font-medium text-white hover:bg-white/10 transition-colors hidden">
            Show More Roles
          </button>
        </div>

        {displayRoles.length === 0 && (
           <div class="p-12 text-center text-muted-foreground">
             No role data found in the current snapshot.
           </div>
        )}
      </div>

    </div>
  </main>
  
  <Footer region={region} />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('roleSearch') as HTMLInputElement;
    const statusFilter = document.getElementById('statusFilter') as HTMLSelectElement;
    const tableBody = document.getElementById('rolesBody');
    const cardsContainer = document.getElementById('rolesCards');
    const loadMoreBtn = document.getElementById('loadMore');
    
    const tableRows = Array.from(tableBody?.querySelectorAll('tr') || []);
    const mobileCards = Array.from(cardsContainer?.querySelectorAll('[data-role]') || []);
    
    const headers = document.querySelectorAll('th[data-sort]');
    const INITIAL_PAGE_SIZE = 15;
    let currentPageSize = INITIAL_PAGE_SIZE;

    let currentSort = 'jobcount';
    let currentDir = 'desc';

    function filterAndSort() {
      const searchTerm = searchInput.value.toLowerCase();
      const statusValue = statusFilter.value;

      const filterFn = (el: Element) => {
        const role = el.getAttribute('data-role') || '';
        const status = el.getAttribute('data-status') || '';
        const skills = el.getAttribute('data-skills') || '';
        const matchesSearch = role.includes(searchTerm) || skills.includes(searchTerm);
        const matchesStatus = statusValue === 'all' || status === statusValue;
        return matchesSearch && matchesStatus;
      };

      const sortFn = (a: Element, b: Element) => {
        let valA: any = a.getAttribute(`data-${currentSort}`);
        let valB: any = b.getAttribute(`data-${currentSort}`);

        if (currentSort === 'jobcount' || currentSort === 'salary' || currentSort === 'growth') {
           valA = parseFloat(valA) || 0;
           valB = parseFloat(valB) || 0;
           return currentDir === 'asc' ? valA - valB : valB - valA;
        } else {
           valA = String(valA);
           valB = String(valB);
           return currentDir === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
        }
      };

      // Apply Filters and Sorting
      let filteredRows = tableRows.filter(filterFn);
      filteredRows.sort(sortFn);

      let filteredCards = mobileCards.filter(filterFn);
      filteredCards.sort(sortFn);

      // Handle "Load More" visibility
      if (filteredRows.length > currentPageSize) {
        loadMoreBtn?.classList.remove('hidden');
      } else {
        loadMoreBtn?.classList.add('hidden');
      }

      // Render limited subset
      if (tableBody) {
        tableBody.innerHTML = '';
        filteredRows.slice(0, currentPageSize).forEach(row => tableBody.appendChild(row));
      }

      if (cardsContainer) {
        cardsContainer.innerHTML = '';
        filteredCards.slice(0, currentPageSize).forEach(card => cardsContainer.appendChild(card));
      }
    }

    loadMoreBtn?.addEventListener('click', () => {
      currentPageSize += 20;
      filterAndSort();
    });

    searchInput?.addEventListener('input', () => {
      currentPageSize = INITIAL_PAGE_SIZE;
      filterAndSort();
    });

    statusFilter?.addEventListener('change', () => {
      currentPageSize = INITIAL_PAGE_SIZE;
      filterAndSort();
    });

    headers.forEach(header => {
      header.addEventListener('click', () => {
        const sortKey = header.getAttribute('data-sort');
        let attrKey = sortKey;
        if (sortKey === 'outlook') attrKey = 'status';
        if (sortKey === 'openings') attrKey = 'jobcount';
        if (sortKey === 'trend') attrKey = 'growth';

        if (currentSort === attrKey) {
          currentDir = currentDir === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort = attrKey || 'jobcount';
          currentDir = 'desc';
        }

        headers.forEach(h => {
           const icon = h.querySelector('.sort-icon');
           if (icon) icon.textContent = '';
        });
        const activeIcon = header.querySelector('.sort-icon');
        if (activeIcon) activeIcon.textContent = currentDir === 'asc' ? '▲' : '▼';

        currentPageSize = INITIAL_PAGE_SIZE;
        filterAndSort();
      });
    });

    // Initial render
    filterAndSort();
  });
</script>
