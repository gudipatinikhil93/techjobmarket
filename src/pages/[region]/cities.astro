---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TrendHighlight from '../../components/TrendHighlight.astro';
import ComparativeAnalytics from '../../components/ComparativeAnalytics.astro';
import IntelligenceCard from '../../components/IntelligenceCard.astro';
import { getAllCities, getWeeklyMovers, getMarketPulse } from '../../services/jobService';
import { getRegion, getRegionConfig } from '../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const [dbCities, weeklyMovers, marketPulse] = await Promise.all([
  getAllCities(region),
  getWeeklyMovers(region, 'city'),
  getMarketPulse(region)
]);

// cityComparison logic for ComparativeAnalytics
const cityComparison = dbCities.slice(0, 2).map(city => ({
  name: city.city,
  metrics: [
    { label: "Hiring Volume", value: `${city.job_count} roles`, score: Math.min(100, (city.job_count / 20) * 100) },
    { label: "Avg Salary", value: `~${(city.avg_salary / (region === 'india' ? 100000 : 1000)).toFixed(1)}${region === 'india' ? 'L' : 'k'}`, score: Math.min(100, (city.avg_salary / (region === 'us' ? 200000 : 3500000)) * 100) },
    { label: "Market Share", value: `${((city.job_count / marketPulse.totalJobs) * 100).toFixed(1)}%`, score: (city.job_count / marketPulse.totalJobs) * 100 }
  ]
}));

const cities = dbCities.length > 0 
  ? dbCities.map(c => {
      const isPeak = c.job_count > 10; // adjusted threshold for actual data volume
      return {
        name: c.city,
        index: Math.min(10, (c.job_count / 10) + 5).toFixed(1), // scaled for data volume
        industries: ["Tech", "IT Services", "Engineering"], // we'd ideally pull from jobs.skills
        status: isPeak ? "Peak" : "Growing",
        description: `Active ${regionConfig.name} Tech Hub with ${c.job_count} current open listings.`,
        salary: c.avg_salary
      };
    })
  : [];

const formatSalary = (num: number) => {
  if (regionConfig.currency.format === 'INR') {
    return `₹${(num / 100000).toFixed(1)}L`;
  }
  return `$${(num / 1000).toFixed(0)}k`;
};
---

<Layout 
  title={`Best Cities for Tech Jobs in ${regionConfig.name} | Top Hiring Hubs`}
  description={`Discover the top hiring cities in the ${regionConfig.name} current tech job market. Compare tech hubs based on live hiring demand.`}
  region={region}
>
  <Navbar region={region} />
  
  <main class="py-24 bg-black min-h-screen">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Hiring Hubs</h1>
        <p class="text-muted-foreground text-lg max-w-2xl">Geographic distribution of tech demand across {regionConfig.name} based on active, live job listings.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 mb-16">
        <div class="lg:col-span-1">
          <TrendHighlight 
            title="City Momentum" 
            type="weekly" 
            movers={weeklyMovers.map(m => ({ name: m.entity_name, change: `${m.wow_growth}%`, isUp: m.wow_growth > 0 }))}
          />
        </div>
        <div class="lg:col-span-2">
          <ComparativeAnalytics 
            title="Tech Hub Head-to-Head" 
            category="Geographic Intelligence"
            entities={cityComparison}
          />
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 mb-16">
        <IntelligenceCard 
          title="Remote Dynamics"
          summary="Remote work remains the largest single category for senior technical roles."
          type="info"
          footer="Consistent across US and India regions."
        />
        <IntelligenceCard 
          title="Satellite Hubs"
          summary="Secondary cities are seeing a surge in IT Services and Support hiring."
          type="positive"
          footer="Growth of 12% MoM in tier-2 cities."
        />
        <IntelligenceCard 
          title="Hub Sourcing"
          summary="Talent concentration is shifting towards specialized AI research hubs."
          type="warning"
          footer="High competition in SF and Bangalore."
        />
      </div>
      
      <!-- Desktop Grid / Mobile Condensed List -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {cities.length > 0 ? cities.map(city => (
          <div class="md:rounded-xl md:border md:border-white/10 md:bg-white/[0.02] p-4 md:p-6 md:hover:border-brand-cyan/30 transition-all group flex flex-row md:flex-col items-center md:items-start justify-between md:justify-start gap-4 border-b border-white/5 md:border-b-0">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-sm md:text-xl font-bold text-white group-hover:text-brand-cyan transition-colors truncate">{city.name}</h3>
                <span class={`text-[8px] md:text-[10px] font-mono uppercase tracking-widest font-bold px-1.5 py-0.5 rounded-[3px] shrink-0 ${city.status === 'Peak' ? 'bg-brand-cyan/10 text-brand-cyan' : 'bg-brand-blue/10 text-brand-blue'}`}>
                  {city.status}
                </span>
              </div>
              <p class="hidden md:block text-sm text-muted-foreground mb-4 flex-grow">{city.description}</p>
              
              <div class="flex items-center gap-4 mt-2 md:mt-0 md:space-y-3 md:pt-4 md:border-t md:border-white/5 md:flex-col md:items-start">
                {city.salary > 0 && (
                  <div class="flex items-center gap-1">
                    <span class="text-[9px] uppercase tracking-wider text-muted-foreground font-bold font-mono">Comp:</span>
                    <span class="text-[10px] md:text-sm font-mono text-white">{formatSalary(city.salary)}</span>
                  </div>
                )}
                <div class="hidden md:block">
                  <p class="text-[10px] uppercase tracking-wider text-muted-foreground font-bold">Key Industries</p>
                  <div class="flex flex-wrap gap-2 mt-2">
                    {city.industries.map(industry => (
                      <span class="text-[10px] bg-white/5 text-white/70 px-2 py-1 rounded-full border border-white/5">
                        {industry}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <div class="text-right shrink-0">
              <span class="block text-[9px] text-muted-foreground uppercase font-mono mb-0.5 tracking-tighter">Hiring Index</span>
              <span class="text-lg md:text-2xl font-bold text-white leading-none">{city.index}</span>
            </div>
          </div>
        )) : (
          <div class="col-span-full p-12 text-center text-muted-foreground italic border border-white/10 rounded-xl bg-white/[0.02]">
            Aggregating city-level job data... Please check back later.
          </div>
        )}
      </div>
      
      <div class="mt-20 p-8 rounded-2xl border border-white/10 bg-white/[0.02] relative overflow-hidden">
        <div class="relative z-10 md:flex items-center justify-between gap-12">
          <div class="mb-8 md:mb-0">
            <h2 class="text-2xl font-bold text-white mb-4">Remote vs On-Site Dynamics</h2>
            <p class="text-muted-foreground max-w-xl">While major hubs still command the highest raw volume, the "Remote" designation remains the largest single category for senior technical roles across {regionConfig.name}.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
