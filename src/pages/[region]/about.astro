---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getRegion, getRegionConfig } from '../../regions';

const region = getRegion(Astro.params);
const regionConfig = getRegionConfig(region);

const dataSources = [
  { name: "Indeed", type: "Job Volume & Salaries" },
  { name: "Greenhouse", type: "Direct ATS Postings" },
  { name: "Lever", type: "Hiring Velocity" },
  { name: "Ashby", type: "Startup Hiring Trends" },
  { name: "RemoteOK", type: "Remote-First Intelligence" },
  { name: "Layoffs.fyi", type: "Market Correction Data" },
];
---

<Layout 
  title={`About TechJobMarket | ${regionConfig.name} Tech Market Intelligence & Analytics`}
  description={`TechJobMarket provides real-time, data-driven intelligence on the ${regionConfig.name} tech job market, including live salary benchmarks, hiring trends, and layoffs tracking.`}
  region={region}
>
  <Navbar region={region} />
  
  <main class="py-24 bg-black">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <!-- Hero Section -->
      <div class="mb-20 text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight">
          Quantifying the <span class="text-brand-cyan">Tech Economy</span>
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed max-w-3xl mx-auto">
          TechJobMarket is a data-first intelligence platform providing transparency into the current {regionConfig.name} tech ecosystem through real-time analytics and AI-driven insights.
        </p>
      </div>

      <div class="space-y-24">
        <!-- Mission Section -->
        <section>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-2xl font-bold text-white mb-6 font-mono uppercase tracking-tight border-l-4 border-brand-cyan pl-4">Our Mission</h2>
              <p class="text-muted-foreground text-lg leading-relaxed mb-6">
                The tech job market moves faster than traditional reporting can track. Information asymmetry often leaves talent and companies in the dark. We built TechJobMarket to democratize access to high-fidelity market data.
              </p>
              <p class="text-muted-foreground text-lg leading-relaxed">
                By aggregating signals from across the web, we provide a unified view of the {regionConfig.name} tech workforce, helping professionals navigate their careers and companies benchmark their growth with confidence.
              </p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-sm">
              <div class="grid grid-cols-2 gap-4 text-center">
                <div class="p-4 bg-black/40 rounded-xl border border-white/5">
                  <div class="text-3xl font-bold text-white mb-1">Live</div>
                  <div class="text-xs text-muted-foreground font-mono uppercase">Analytics</div>
                </div>
                <div class="p-4 bg-black/40 rounded-xl border border-white/5">
                  <div class="text-3xl font-bold text-brand-cyan mb-1">AI</div>
                  <div class="text-xs text-muted-foreground font-mono uppercase">Insights</div>
                </div>
                <div class="p-4 bg-black/40 rounded-xl border border-white/5">
                  <div class="text-3xl font-bold text-white mb-1">Multi</div>
                  <div class="text-xs text-muted-foreground font-mono uppercase">Source</div>
                </div>
                <div class="p-4 bg-black/40 rounded-xl border border-white/5">
                  <div class="text-3xl font-bold text-white mb-1">{regionConfig.id.toUpperCase()}</div>
                  <div class="text-xs text-muted-foreground font-mono uppercase">Focused</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Intelligence Pipeline -->
        <section class="p-8 md:p-12 rounded-3xl border border-white/10 bg-card/50 relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 opacity-10">
            <svg class="h-48 w-48 text-brand-cyan" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
          </div>
          
          <h2 class="text-3xl font-bold text-white mb-8">The Intelligence Pipeline</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
            <div class="space-y-4">
              <div class="h-10 w-10 rounded-lg bg-brand-cyan/20 flex items-center justify-center text-brand-cyan font-bold">1</div>
              <h3 class="text-xl font-bold text-white">Multi-Signal Ingestion</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                We track thousands of data points daily from premium sources like Greenhouse, Lever, Ashby, and Indeed to capture hiring velocity at the source.
              </p>
            </div>
            <div class="space-y-4">
              <div class="h-10 w-10 rounded-lg bg-brand-cyan/20 flex items-center justify-center text-brand-cyan font-bold">2</div>
              <h3 class="text-xl font-bold text-white">AI Normalization</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                Using advanced NLP and LLMs (Gemini Pro), we normalize job titles, extract skill requirements, and synthesize complex market signals into readable trends.
              </p>
            </div>
            <div class="space-y-4">
              <div class="h-10 w-10 rounded-lg bg-brand-cyan/20 flex items-center justify-center text-brand-cyan font-bold">3</div>
              <h3 class="text-xl font-bold text-white">Real-Time Synthesis</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                Our dashboard updates continuously, reflecting shifts in salary benchmarks, layoffs, and emerging technology demands as they happen.
              </p>
            </div>
          </div>
        </section>

        <!-- Data Sources -->
        <section>
          <h2 class="text-2xl font-bold text-white mb-8 text-center uppercase tracking-widest font-mono">Our Data Ecosystem</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            {dataSources.map(source => (
              <div class="p-4 rounded-xl border border-white/5 bg-white/[0.02] text-center group hover:border-brand-cyan/30 transition-all">
                <div class="text-white font-bold mb-1 group-hover:text-brand-cyan transition-colors">{source.name}</div>
                <div class="text-[10px] text-muted-foreground uppercase font-mono tracking-tighter">{source.type}</div>
              </div>
            ))}
          </div>
          <p class="text-center text-muted-foreground text-xs mt-8 italic">
            *TechJobMarket is not affiliated with these entities; we process publicly available data and ATS feeds for market research.
          </p>
        </section>

        <!-- Values -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-12 border-t border-white/10 pt-24">
          <div>
            <h2 class="text-2xl font-bold text-white mb-4">Analytical Integrity</h2>
            <p class="text-muted-foreground leading-relaxed">
              We provide objective market intelligence. Unlike recruitment agencies, we do not take placement fees or commissions. Our primary product is the data itself, ensuring our reports remain unbiased and focused on factual market movements.
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-white mb-4">Production-Ready Intelligence</h2>
            <p class="text-muted-foreground leading-relaxed">
              Every data point is cross-referenced. We track salary transparency disclosures and verify layoffs through multiple public signals to ensure the most accurate market picture available to the public.
            </p>
          </div>
        </section>

        <!-- Transparency & Methodology -->
        <section class="py-24 border-t border-white/10">
          <div class="max-w-4xl">
            <h2 class="text-3xl font-bold text-white mb-8 tracking-tight">Methodology & Source Transparency</h2>
            <div class="space-y-12">
              <div class="grid md:grid-cols-3 gap-8">
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5">
                  <div class="text-[10px] font-mono text-brand-cyan uppercase tracking-widest mb-2">Update Frequency</div>
                  <div class="text-xl font-bold text-white">Live Every 6h</div>
                  <p class="text-xs text-muted-foreground mt-2">Continuous scraping and normalization pipelines.</p>
                </div>
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5">
                  <div class="text-[10px] font-mono text-brand-cyan uppercase tracking-widest mb-2">Data Confidence</div>
                  <div class="text-xl font-bold text-white">High (85%+)</div>
                  <p class="text-xs text-muted-foreground mt-2">Verified against direct ATS feeds and SEC filings.</p>
                </div>
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5">
                  <div class="text-[10px] font-mono text-brand-cyan uppercase tracking-widest mb-2">Coverage</div>
                  <div class="text-xl font-bold text-white">15,000+ Jobs</div>
                  <p class="text-xs text-muted-foreground mt-2">Active tracked listings across {regionConfig.name}.</p>
                </div>
              </div>

              <div class="prose prose-invert max-w-none text-muted-foreground">
                <h3 class="text-white">How we process market signals</h3>
                <p>
                  Our proprietary engine uses a multi-stage pipeline to ensure data fidelity. First, we ingest raw job descriptions from thousands of sources. These are then processed using <strong>Gemini 2.0 Flash</strong> for high-speed title normalization and skill extraction.
                </p>
                <p>
                  Salary data is processed using a "Median-Filtering" approach to remove extreme outliers and unreliable disclosures. We prioritize listings that specify a salary range over general market estimates to maintain the integrity of our benchmarks.
                </p>
                <p>
                  <strong>Historical drift</strong> is calculated by comparing weekly snapshot captures (taken every Sunday at 00:00 UTC) against the current 7-day rolling average. This allows us to filter out daily noise and identify sustainable market trends.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Contact/CTA -->
        <div class="text-center py-12">
          <p class="text-sm font-mono text-muted-foreground uppercase mb-6 tracking-widest italic">Empowering the next generation of tech talent</p>
          <div class="flex justify-center gap-6">
            <a href={`/${region}/contact`} class="px-8 py-3 rounded-full bg-white text-black font-bold hover:bg-brand-cyan transition-all active:scale-95">
              Contact Us
            </a>
            <a href={`/${region}/trends`} class="px-8 py-3 rounded-full border border-white/10 text-white font-bold hover:bg-white/5 transition-all">
              Explore Trends
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer region={region} />
</Layout>
