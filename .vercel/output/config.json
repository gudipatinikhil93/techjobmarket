{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/scrape/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/top-cities/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/trending-roles/?$",
			"dest": "_render"
		},
		{
			"src": "^/cities/?$",
			"dest": "_render"
		},
		{
			"src": "^/role/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/roles/?$",
			"dest": "_render"
		},
		{
			"src": "^/salaries/?$",
			"dest": "_render"
		},
		{
			"src": "^/search/?$",
			"dest": "_render"
		},
		{
			"src": "^/skills/?$",
			"dest": "_render"
		},
		{
			"src": "^/trends/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}