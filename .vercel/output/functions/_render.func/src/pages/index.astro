---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getTopCities, getMarketPulse, getHiringTrends, getSalaryBenchmarks } from '../services/jobService';
import { getMarketOutlook } from '../services/outlookService';
import { getLatestInsights } from '../services/aiService';

// Fetch real data from services
const marketPulse = await getMarketPulse();
const marketInsights = await getLatestInsights();
const topCities = await getTopCities();
const salaryBenchmarks = await getSalaryBenchmarks();
const hiringTrends = await getHiringTrends();
const marketOutlook = await getMarketOutlook();

// Safe defaults if db lacks data
const safeMarketOutlook = marketOutlook || [];
const growingRoles = safeMarketOutlook.filter(r => r.status === 'Growing' || r.growth_percentage > 0).slice(0, 5);
const decliningRoles = safeMarketOutlook.filter(r => r.status === 'Declining' || r.growth_percentage < 0).slice(0, 5);

// Check if we have enough historical data to show real charts
const hasSufficientTrendData = hiringTrends && hiringTrends.length >= 3;

// Format numbers
const formatSalary = (num: number) => `$${(num / 1000).toFixed(0)}k`;
---

<Layout 
	title="US Tech Job Market Intelligence | Live Hiring Trends 2026"
	description="Live intelligence overview of the US tech job market. Track hiring momentum, growing roles, salary realities, and market trends."
>
	<Navbar />
	
	<main class="relative bg-black min-h-screen selection:bg-brand-cyan/30">
		
		<!-- 1. HERO MARKET PULSE -->
		<section class="mesh-gradient relative overflow-hidden pt-32 pb-16 lg:pt-40 lg:pb-20 border-b border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
				
				<div class="flex items-center gap-3 mb-6">
					<div class="relative flex h-3 w-3">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-cyan opacity-75"></span>
						<span class="relative inline-flex rounded-full h-3 w-3 bg-brand-cyan"></span>
					</div>
					<span class="text-sm font-mono text-brand-cyan tracking-wider uppercase">Live Market Pulse</span>
				</div>

				<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-tight">
					Intelligence for the <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white/80 to-white/40">US Tech Market</span>
				</h1>
				
				<p class="max-w-2xl text-lg md:text-xl text-muted-foreground mb-16 leading-relaxed">
					Real-time data visualization of hiring velocity, skill demand, and salary compression across the United States. No noise, just data.
				</p>

				<!-- Pulse Indicators Grid -->
				<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-white/20 transition-colors">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Hiring Velocity</span>
						<div class="flex items-baseline gap-2">
							<span class="text-2xl font-bold text-white">{marketPulse.hiringIndex.toFixed(1)}/10</span>
							<span class="text-xs font-medium text-brand-cyan">Stable</span>
						</div>
					</div>
					
					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-white/20 transition-colors">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Market Outlook</span>
						<div class="flex items-baseline gap-2">
							<span class="text-2xl font-bold text-white">Cautious</span>
						</div>
					</div>

					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-white/20 transition-colors">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Total Open Roles</span>
						<div class="flex items-baseline gap-2">
							<span class="text-2xl font-bold text-white">{(marketPulse.totalJobs / 1000).toFixed(1)}k</span>
							{marketPulse.recentJobs > 0 && (
								<span class="text-xs font-medium text-brand-cyan">+{marketPulse.recentJobs} new</span>
							)}
						</div>
					</div>

					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-white/20 transition-colors">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Median Base</span>
						<div class="flex items-baseline gap-2">
							<span class="text-2xl font-bold text-white">{formatSalary(marketPulse.avgSalary)}</span>
						</div>
					</div>

					<div class="p-5 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-white/20 transition-colors hidden lg:block">
						<span class="block text-xs font-mono text-muted-foreground uppercase tracking-widest mb-2">Remote Trend</span>
						<div class="flex items-baseline gap-2">
							<span class="text-2xl font-bold text-white">Declining</span>
							<span class="text-xs font-medium text-brand-magenta">RTO Push</span>
						</div>
					</div>
				</div>
			</div>
			
			<div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-blue/10 rounded-full blur-[120px] -z-10 pointer-events-none translate-x-1/3 -translate-y-1/3"></div>
		</section>

		<!-- 2. MARKET STORYTELLING -->
		<section class="py-8 bg-black border-b border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col md:flex-row gap-6 lg:gap-12 items-start md:items-center">
					<div class="shrink-0 flex items-center gap-3">
						<div class="h-8 w-8 rounded bg-brand-magenta/10 border border-brand-magenta/30 flex items-center justify-center text-brand-magenta">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
						</div>
						<span class="text-xs font-bold uppercase tracking-widest text-white/50">Intelligence<br/>Briefing</span>
					</div>
					<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 flex-1 w-full">
						{marketInsights.slice(0, 3).map((insight: string) => (
							<p class="text-sm text-muted-foreground leading-relaxed border-l-2 border-white/10 pl-4 py-1">
								{insight}
							</p>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- 3. HIRING MOMENTUM & HEATMAP -->
		<section class="py-20 lg:py-32 relative">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-16">
					
					<!-- Momentum Chart -->
					<div>
						<div class="mb-8">
							<h2 class="text-2xl font-bold text-white mb-2">Hiring Momentum</h2>
							<p class="text-muted-foreground text-sm">Overall market velocity across captured US tech hubs.</p>
						</div>
						
						<div class="h-[300px] w-full rounded-2xl border border-white/10 bg-white/[0.01] p-6 relative flex items-end">
							{hasSufficientTrendData ? (
								<div class="w-full h-full flex items-end justify-between gap-2">
									{hiringTrends.map((point: any, index: number) => {
										// Calculate dynamic height based on values. Fallback generic logic for safety.
										const maxVal = Math.max(...hiringTrends.map((p: any) => p.value));
										const minVal = Math.min(...hiringTrends.map((p: any) => p.value));
										const range = maxVal - minVal || 1;
										const normalizedHeight = ((point.value - minVal) / range) * 60 + 20; // 20% to 80%
										
										return (
											<div class="flex-1 flex flex-col items-center gap-2 group relative">
												<div class="w-full rounded-t bg-gradient-to-t from-brand-blue/20 to-brand-cyan/50 hover:to-brand-cyan transition-all" style={`height: ${normalizedHeight}%`}>
													<div class="absolute -top-10 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 bg-white text-black text-xs font-bold py-1 px-2 rounded transition-opacity whitespace-nowrap pointer-events-none">
														{point.value} jobs
													</div>
												</div>
												<span class="text-[10px] text-muted-foreground uppercase">{point.month}</span>
											</div>
										)
									})}
								</div>
							) : (
								<div class="w-full h-full flex flex-col items-center justify-center text-center">
									<div class="h-12 w-12 rounded-full border border-white/10 flex items-center justify-center mb-4 text-white/20">
										<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
									</div>
									<h3 class="text-white font-medium mb-1">Historical Trend Analysis Initializing</h3>
									<p class="text-sm text-muted-foreground">Collecting sufficient historical database snapshots to generate high-confidence momentum charts.</p>
								</div>
							)}
						</div>
					</div>

					<!-- Top Cities Heatmap style -->
					<div>
						<div class="mb-8">
							<h2 class="text-2xl font-bold text-white mb-2">Top Hiring Geographies</h2>
							<p class="text-muted-foreground text-sm">Active volume concentration by major tech hub.</p>
						</div>

						<div class="space-y-4">
							{topCities && topCities.length > 0 ? topCities.map((city: any, index: number) => {
								const maxJobs = Math.max(...topCities.map((c: any) => c.job_count));
								const width = Math.max(10, (city.job_count / maxJobs) * 100);
								return (
									<div class="group">
										<div class="flex justify-between items-end mb-2">
											<span class="text-sm font-bold text-white">{city.city}</span>
											<span class="text-xs font-mono text-muted-foreground">{city.job_count} open roles</span>
										</div>
										<div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
											<div class="h-full bg-brand-cyan rounded-full transition-all duration-1000 group-hover:bg-white" style={`width: ${width}%`}></div>
										</div>
									</div>
								)
							}) : (
								<div class="p-8 rounded-2xl border border-white/10 text-center">
									<p class="text-sm text-muted-foreground">Aggregating geographic data...</p>
								</div>
							)}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- 4. GROWING VS DECLINING ROLES -->
		<section class="py-20 lg:py-32 bg-white/[0.02] border-y border-white/5">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl font-bold text-white mb-4">Demand Trajectory</h2>
					<p class="text-muted-foreground max-w-2xl mx-auto">Market intelligence identifying which technical domains are accelerating and which are facing saturation or declining demand.</p>
				</div>

				<div class="grid md:grid-cols-2 gap-8 lg:gap-16">
					<!-- Growing -->
					<div class="rounded-2xl border border-brand-cyan/20 bg-brand-cyan/[0.02] overflow-hidden">
						<div class="p-6 border-b border-brand-cyan/10 bg-brand-cyan/5">
							<h3 class="text-xl font-bold text-white flex items-center gap-2">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-cyan"><path d="M23 6l-9.5 9.5-5-5L1 18"></path><path d="M17 6h6v6"></path></svg>
								Accelerating Roles
							</h3>
						</div>
						<div class="p-6 space-y-6">
							{growingRoles.length > 0 ? growingRoles.map((role: any) => (
								<div class="flex items-start justify-between gap-4">
									<div>
										<h4 class="font-bold text-white mb-1">{role.role}</h4>
										<p class="text-xs text-muted-foreground">{role.insight || `${role.job_count} active listings`}</p>
									</div>
									<div class="shrink-0 text-right">
										<span class="block font-mono font-bold text-brand-cyan">+{role.growth_percentage}%</span>
									</div>
								</div>
							)) : (
								<div class="text-center py-8 text-muted-foreground text-sm">Insufficient growth confidence data.</div>
							)}
						</div>
					</div>

					<!-- Declining -->
					<div class="rounded-2xl border border-brand-magenta/20 bg-brand-magenta/[0.02] overflow-hidden">
						<div class="p-6 border-b border-brand-magenta/10 bg-brand-magenta/5">
							<h3 class="text-xl font-bold text-white flex items-center gap-2">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-magenta"><path d="M23 18l-9.5-9.5-5 5L1 6"></path><path d="M17 18h6v-6"></path></svg>
								Cooling Demand
							</h3>
						</div>
						<div class="p-6 space-y-6">
							{decliningRoles.length > 0 ? decliningRoles.map((role: any) => (
								<div class="flex items-start justify-between gap-4">
									<div>
										<h4 class="font-bold text-white mb-1">{role.role}</h4>
										<p class="text-xs text-muted-foreground">{role.insight || `${role.job_count} active listings`}</p>
									</div>
									<div class="shrink-0 text-right">
										<span class="block font-mono font-bold text-brand-magenta">{role.growth_percentage}%</span>
									</div>
								</div>
							)) : (
								<div class="text-center py-8 text-muted-foreground text-sm">Insufficient decline confidence data.</div>
							)}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- 5. SALARY REALITY -->
		<section class="py-20 lg:py-32">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
					<div>
						<h2 class="text-3xl font-bold text-white mb-4">Salary Reality Visualization</h2>
						<p class="text-muted-foreground max-w-xl">Current baseline vs ceiling compensation across US tech hubs. Excludes outlier equity packages to show realistic base expectations.</p>
					</div>
					<a href="/salaries" class="shrink-0 rounded-full border border-white/10 bg-white/5 px-6 py-2 text-sm font-bold text-white hover:bg-white/10 transition-colors">
						View Detailed Benchmarks
					</a>
				</div>

				<div class="bg-white/[0.02] border border-white/10 rounded-2xl overflow-hidden">
					<div class="grid grid-cols-12 gap-4 p-4 border-b border-white/10 text-xs font-mono text-muted-foreground uppercase tracking-wider bg-white/[0.02]">
						<div class="col-span-5 md:col-span-4">Role / Domain</div>
						<div class="col-span-7 md:col-span-8">Compensation Range (USD)</div>
					</div>
					
					<div class="divide-y divide-white/5">
						{salaryBenchmarks && salaryBenchmarks.length > 0 ? salaryBenchmarks.map((benchmark: any) => {
							// Determine bar position. Let's assume absolute min is $50k and max is $350k for US Tech
							const ABSOLUTE_MIN = 50000;
							const ABSOLUTE_MAX = 350000;
							const range = ABSOLUTE_MAX - ABSOLUTE_MIN;
							
							const minPercent = Math.max(0, ((benchmark.avg_min - ABSOLUTE_MIN) / range) * 100);
							const widthPercent = Math.min(100 - minPercent, ((benchmark.avg_max - benchmark.avg_min) / range) * 100);
							
							return (
								<div class="grid grid-cols-12 gap-4 p-4 items-center hover:bg-white/[0.02] transition-colors">
									<div class="col-span-5 md:col-span-4">
										<span class="text-sm font-bold text-white block">{benchmark.role}</span>
									</div>
									<div class="col-span-7 md:col-span-8 flex items-center gap-4">
										<span class="text-xs font-mono text-muted-foreground w-16 text-right shrink-0">{formatSalary(benchmark.avg_min)}</span>
										<div class="flex-1 h-3 rounded-full bg-black border border-white/5 relative overflow-hidden hidden sm:block">
											<div 
												class="absolute h-full rounded-full bg-gradient-to-r from-brand-blue/50 to-brand-cyan/80 border border-white/10"
												style={`left: ${minPercent}%; width: ${widthPercent}%;`}
											></div>
										</div>
										<span class="text-xs font-mono text-white w-16 shrink-0">{formatSalary(benchmark.avg_max)}</span>
									</div>
								</div>
							)
						}) : (
							<div class="p-8 text-center text-muted-foreground text-sm">
								Initializing compensation datasets...
							</div>
						)}
					</div>
				</div>
			</div>
		</section>

	</main>

	<Footer />
</Layout>