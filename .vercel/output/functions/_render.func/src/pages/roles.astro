---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getAllRoles } from '../services/jobService';

const fallbackRoles = [
  { name: "AI Engineer", category: "Engineering", salary: "$140k - $220k", demand: "Critical" },
  { name: "Full Stack Developer", category: "Engineering", salary: "$110k - $160k", demand: "High" },
  { name: "Product Manager", category: "Product", salary: "$130k - $180k", demand: "High" },
  { name: "Data Scientist", category: "Data", salary: "$125k - $175k", demand: "Very High" },
  { name: "Cloud Architect", category: "Infrastructure", salary: "$160k - $240k", demand: "Critical" },
  { name: "UI/UX Designer", category: "Design", salary: "$95k - $150k", demand: "Medium" },
  { name: "DevOps Engineer", category: "Infrastructure", salary: "$130k - $190k", demand: "High" },
  { name: "Cybersecurity Analyst", category: "Security", salary: "$115k - $170k", demand: "Very High" },
];

const dbRoles = await getAllRoles();

const roles = dbRoles.length > 0
  ? dbRoles.map(r => ({
      name: r.role,
      category: "Tech",
      salary: "Market Rate",
      demand: r.job_count > 50 ? "Critical" : "High"
    }))
  : fallbackRoles;
---

<Layout 
  title="Trending Tech Job Roles in US 2026 | Current Job Market Analysis"
  description="Explore the most in-demand job roles in the US tech market. Analyze salary benchmarks, hiring demand, and growth trends for 2026."
>
  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Trending Job Roles</h1>
        <p class="text-muted-foreground text-lg">In-depth analysis of the most in-demand roles in the US tech ecosystem.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {roles.map(role => (
          <a href={`/role/${encodeURIComponent(role.name)}`} class="rounded-xl border border-white/10 bg-card p-6 hover:border-brand-cyan/30 transition-all group">
            <div class="flex justify-between items-start mb-4">
              <span class="text-xs font-mono text-brand-cyan uppercase tracking-widest">{role.category}</span>
              <span class={`px-2 py-0.5 rounded text-[10px] font-bold uppercase ${role.demand === 'Critical' ? 'bg-brand-magenta/20 text-brand-magenta' : 'bg-brand-cyan/20 text-brand-cyan'}`}>
                {role.demand}
              </span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-cyan transition-colors">{role.name}</h3>
            <p class="text-sm text-muted-foreground mb-6">Average Base Salary: <span class="text-white font-medium">{role.salary}</span></p>
            <span class="text-sm font-bold text-white/50 group-hover:text-white transition-colors">View detailed breakdown →</span>
          </a>
        ))}
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
