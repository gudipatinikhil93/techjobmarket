---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getRoleIntelligence } from '../../services/outlookService';

const { role } = Astro.params;
const decodedRole = decodeURIComponent(role || '');
const intelligence = await getRoleIntelligence(decodedRole);

if (!intelligence) {
  return Astro.redirect('/roles');
}

const statusColors = {
  Growing: 'bg-green-500/20 text-green-400',
  Stable: 'bg-brand-cyan/20 text-brand-cyan',
  Declining: 'bg-orange-500/20 text-orange-400',
  Oversaturated: 'bg-brand-magenta/20 text-brand-magenta',
};
---

<Layout 
  title={`${intelligence.role} Market Outlook & Salary in India 2026 | JobMarketIndia`}
  description={`What is the current job market like for ${intelligence.role} in India? Discover 2026 salary trends, top hiring cities, and key skills for ${intelligence.role} positions.`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://jobmarketindia.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Roles",
        "item": "https://jobmarketindia.com/roles"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": intelligence.role,
        "item": `https://jobmarketindia.com/role/${role}`
      }
    ]
  })} />

  <Navbar />
  
  <main class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-muted-foreground">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span>/</span></li>
          <li><a href="/roles" class="hover:text-white transition-colors">Roles</a></li>
          <li><span>/</span></li>
          <li class="text-white font-medium">{intelligence.role}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Stats -->
        <div class="lg:col-span-2 space-y-12">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <h1 class="text-4xl font-bold text-white tracking-tight">{intelligence.role} Job Market India</h1>
              <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase ${statusColors[intelligence.status]}`}>
                {intelligence.status}
              </span>
            </div>
            <p class="text-xl text-muted-foreground leading-relaxed">
              Analysis of the <strong>current job market for {intelligence.role}</strong> in India. {intelligence.insight}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Active Openings</span>
              <p class="text-3xl font-bold text-white mt-2">{intelligence.jobCount}</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Growth (7d)</span>
              <p class={`text-3xl font-bold mt-2 ${intelligence.growthPercentage >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                {intelligence.growthPercentage}%
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-card p-6">
              <span class="text-xs font-mono text-muted-foreground uppercase tracking-widest">Avg. LPA 2026</span>
              <p class="text-3xl font-bold text-white mt-2">
                ₹{Math.round(intelligence.avgSalaryMin / 100000)}L - ₹{Math.round(intelligence.avgSalaryMax / 100000)}L
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-white mb-6">Deep Market Analysis: {intelligence.role}</h2>
            <div class="prose prose-invert max-w-none">
              <p>
                Based on current market data, the role of <strong>{intelligence.role}</strong> is currently seeing a 
                {intelligence.status.toLowerCase()} trend in the Indian tech ecosystem. The average salary range in India for this position currently spans from 
                ₹{intelligence.avgSalaryMin.toLocaleString('en-IN')} to ₹{intelligence.avgSalaryMax.toLocaleString('en-IN')} per annum, reflecting the <strong>current job market trends</strong> for 2026.
              </p>
              <p>
                The highest demand for <strong>{intelligence.role}</strong> is currently concentrated in major hubs like <strong>{intelligence.topCities.join(', ')}</strong>. 
                Employers are prioritizing candidates with proficiency in <strong>{intelligence.keySkills.join(', ')}</strong>, which are essential for staying competitive in the <strong>current job market for software engineers</strong> and related fields.
              </p>
              <p>
                Compared to last year, the hiring velocity for this role has changed by {intelligence.growthPercentage}%, indicating a {intelligence.growthPercentage >= 0 ? 'strengthening' : 'shifting'} demand. For professionals looking to enter or advance in this field, focusing on {intelligence.keySkills[0]} and {intelligence.keySkills[1]} is highly recommended.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="rounded-xl border border-brand-cyan/20 bg-brand-cyan/5 p-8">
            <h3 class="text-lg font-bold text-white mb-4">Top Hiring Cities</h3>
            <ul class="space-y-4">
              {intelligence.topCities.map(city => (
                <li class="flex items-center justify-between">
                  <span class="text-muted-foreground">{city}</span>
                  <span class="h-1.5 w-1.5 rounded-full bg-brand-cyan"></span>
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-xl border border-white/10 bg-card p-8">
            <h3 class="text-lg font-bold text-white mb-4">In-Demand Skills</h3>
            <div class="flex flex-wrap gap-2">
              {intelligence.keySkills.map(skill => (
                <span class="px-3 py-1 rounded-lg border border-white/10 bg-white/5 text-sm text-white">
                  {skill}
                </span>
              ))}
            </div>
          </div>
          
          <div class="p-6 rounded-xl bg-brand-magenta/10 border border-brand-magenta/20">
             <h4 class="font-bold text-white mb-2">Data Transparency</h4>
             <p class="text-xs text-muted-foreground">
               This intelligence is generated based on {intelligence.jobCount} real-time job listings from Indeed, Wellfound, and direct career pages. Analytics are updated weekly.
             </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
